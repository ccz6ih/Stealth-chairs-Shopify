{% endcomment %}
{% if request.design_mode == true %}
<p class="QQ-JS-init-msg" style="display:block;padding: 10px 15px;text-align: center;max-width: 450px;background-color: #d5d5d5;color: red;border: 1px solid red;border-radius: 10px;margin: 0 auto;">Please save the Theme Editor before adding content or changing settings in order to initiate functionality.</p>
{% endif %}
{% liquid
    assign contentMaxWidth = section.settings.content_max_width
    assign contentFullwidth = section.settings.content_fullwidth
    assign blockImageColumnWidth = section.settings.block_media_column_width
    assign blockTextWidth = 100 | minus: blockImageColumnWidth
    assign sectionClass = section.settings.section_class
    assign sectionWidth = section.settings.section_width
    assign sectionBackgroundColor = section.settings.background_color
    assign textAreaVerticalPosition = section.settings.text_vertical_position
    assign textAreaTextAlign = section.settings.text_alignment
    assign textAreaTextAlignMobile = section.settings.text_alignment_mobile
    if textAreaTextAlign == 'left'
      assign buttonsAlignment = 'flex-start'
    elsif textAreaTextAlign == 'right'
      assign buttonsAlignment = 'flex-end'
    else
      assign buttonsAlignment = textAreaTextAlign
    endif
    if textAreaTextAlignMobile == 'left'
      assign buttonsAlignmentMobile = 'flex-start'
    elsif textAreaTextAlignMobile == 'right'
      assign buttonsAlignmentMobile = 'flex-end'
    else
      assign buttonsAlignmentMobile = textAreaTextAlignMobile
    endif
    assign sectionMarginTop = section.settings.section_margin_top
    assign sectionMarginTopMobile = section.settings.section_margin_top_mobile
    assign sectionMarginBottom = section.settings.section_margin_bottom
    assign sectionMarginBottomMobile = section.settings.section_margin_bottom_mobile
    assign sectionPaddingHorizontal = section.settings.section_padding_horizontal
    assign sectionPaddingHorizontalMobile = section.settings.section_padding_horizontal_mobile
    assign sectionPaddingTop = section.settings.section_padding_top
    assign sectionPaddingTopMobile = section.settings.section_padding_top_mobile
    assign sectionPaddingBottom = section.settings.section_padding_bottom
    assign sectionPaddingBottomMobile = section.settings.section_padding_bottom_mobile
    assign textAreaPaddingRight = section.settings.text_area_padding_right
    assign textAreaPaddingLeft = section.settings.text_area_padding_left
    assign textAreaPaddingHorizontalMobile = section.settings.text_area_padding_horizontal_mobile
    assign textAreaPaddingTop = section.settings.text_area_padding_top
    assign textAreaPaddingTopMobile = section.settings.text_area_padding_top_mobile
    assign textAreaPaddingBottom = section.settings.text_area_padding_bottom
    assign textAreaPaddingBottomMobile = section.settings.text_area_padding_bottom_mobile
    assign buttonsMargin = section.settings.buttons_margin
    assign buttonsLayout = section.settings.buttons_layout        
%}
{% assign buttonCounter = 1 %}
{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when 'image' -%}
      {% liquid
        assign imagePosition = block.settings.image_position
        assign imagePositionMobile = block.settings.image_position_mobile
        if imagePosition == 'right'
          assign blocksOrder = 'qq-row'
        elsif imagePosition == 'left'
          assign blocksOrder = 'qq-row-reverse'
        endif
        if imagePositionMobile == 'top'
          assign blocksOrderMobile = 'qq-column-reverse'
        elsif imagePositionMobile == 'bottom'
          assign blocksOrderMobile = 'qq-column'
        elsif imagePositionMobile == 'hidden'
          assign blocksOrderMobile = 'qq-column'
          assign imageClass = 'hidden-on-mobile'
        endif
        assign imageSize = block.settings.image_size
        assign imageWidth = block.settings.image_width
        assign image = block.settings.image
        assign proportion = image.aspect_ratio
        assign imageImgW = image.width
        assign imageImgH = image.height
        assign maxWidthAllowed = 1920
        assign maxHeightAllowed = 1080
        if proportion > 1
          # landscape
          assign mostW = maxWidthAllowed
          assign mostH = mostW | times: proportion
        elsif proportion < 1
          # portrait
          assign mostH = maxHeightAllowed
          assign mostW = mostH | times: proportion
        else
          # sqaure
          assign mostW = maxWidthAllowed
          assign mostH = mostW
        endif
        assign iw = imageImgW | at_most: mostW | round
        assign ih = imageImgH | at_most: mostH | round
        if imageWidth == 'fullwidth'
          assign maxWidthAllowed = 1920
          assign maxHeightAllowed = 1280
        else 3
          assign maxWidthAllowed = 900
          assign maxHeightAllowed = 900
        endif
        if proportion > 1
          # landscape
          assign mostW = maxWidthAllowed
          assign mostH = mostW | times: proportion
        elsif proportion < 1
          # portrait
          assign mostH = maxHeightAllowed
          assign mostW = mostH | times: proportion
        else
          # sqaure
          assign mostW = maxWidthAllowed
          assign mostH = mostW
        endif
        assign iw = imageImgW | at_most: mostW | round
        assign ih	= imageImgH | at_most: mostH | round
        if imageSize == 'square'
          assign ih = iw
          if iw > imageImgW
            assign iw = imageImgW
            assign ih = iw
          endif
          if ih > imageImgH
            assign ih = imageImgH
            assign iw = ih
          endif
        elsif imageSize == 'landscape'
          assign ih = iw | divided_by: 1.5 | round
          if imageImgH < ih
            assign ih = imageImgH
            assign iw = ih | divided_by: 0.666667 | round
          endif
          if imageImgW < iw
            assign iw = imageImgW
            assign ih = iw | divided_by: 1.5 | round
          endif
        elsif imageSize == 'original'
          assign ih = iw | divided_by: proportion | round
        endif
        assign size = iw | append: 'x' | append: ih
        assign imageUrl = image | img_url: size, crop: 'center'
        if image.alt != blank 
          assign imageAlt = 'alt="' | append: image.alt | append: '"'
        else 
          assign imageAlt = ''
        endif
      %}
        {% capture imageElement %}
          <div class="{% if imageWidth == 'fullwidth' %}full{%endif%}{% if imageClass != blank %} qq-{{imageClass}}{%endif%}">
            {% if image != blank %}
              <img src="{{imageUrl}}" {{imageAlt}} loading="lazy">
            {% else %}
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 771 771" style="width:100%;height:100%;" preserveAspectRatio="xMidYMid slice"><g style="isolation:isolate"><g id="Layer_2" data-name="Layer 2"><g id="Layer_1-2" data-name="Layer 1" style="fill:#efefef;"><rect width="771" height="771" style="fill:#efefef;"/><g style="opacity:0.5"><path d="M280.73,441.53V406.12h-.48c-3,6.78-8.91,10.7-17.23,10.7-14.49,0-23-11.77-23-30.42S248.41,356,263.14,356c8.79,0,14.74,4,17.59,11.28h.47l.6-9.86H290v84.13Zm0-53.71V385c0-12.83-6.42-20.44-16-20.44s-15.1,7.72-15.1,21.87,5.47,21.86,15.1,21.86S280.73,400.66,280.73,387.82Z" style="fill:#373833"/><path d="M302.48,357.4h8.91l7.72,44.09h.48l10-44.09h7.49l10,44.09h.47l7.73-44.09h8.55l-10.81,58h-9.87l-9.74-43h-.47l-9.75,43h-9.86Z" style="fill:#373833"/><path d="M376.86,407.19h20V365.6h-20v-8.2h29.23v49.79h20v8.2h-49.2Zm15.21-69.52a8.08,8.08,0,1,1,8.08,8.09A7.87,7.87,0,0,1,392.07,337.67Z" style="fill:#373833"/><path d="M471.45,441.53V406.12H471c-3,6.78-8.92,10.7-17.23,10.7-14.5,0-23.06-11.77-23.06-30.42S439.13,356,453.86,356c8.8,0,14.74,4,17.59,11.28h.48l.59-9.86h8.2v84.13Zm0-53.71V385c0-12.83-6.41-20.44-16-20.44s-15.09,7.72-15.09,21.87,5.47,21.86,15.09,21.86S471.45,400.66,471.45,387.82Z" style="fill:#373833"/><path d="M492.72,386.4c0-19.73,8.8-30.42,25.19-30.42s25.2,10.69,25.2,30.42-8.8,30.42-25.2,30.42S492.72,406.12,492.72,386.4Zm40.76,0c0-14.38-5.35-21.87-15.57-21.87S502.35,372,502.35,386.4s5.35,21.86,15.56,21.86S533.48,400.77,533.48,386.4Z" style="fill:#373833"/><path d="M553.09,386.4c0-18.66,8.55-30.42,23-30.42,8.32,0,14.26,3.92,17.23,10.69h.48V331h9.27v84.37h-8.2l-.6-9.86h-.47c-2.85,7.25-8.8,11.29-17.59,11.29C561.52,416.82,553.09,405.17,553.09,386.4Zm40.76,1.42V385c0-12.83-6.42-20.44-16.05-20.44s-15.09,7.72-15.09,21.87,5.47,21.86,15.09,21.86S593.85,400.66,593.85,387.82Z" style="fill:#373833"/><path d="M615.36,386.28c0-19.61,8.79-30.3,25.31-30.3S666,366.67,666,386.28a18.15,18.15,0,0,1-.12,2.49H625c.59,13,6.06,19.49,16.52,19.49,6.53,0,11-2.61,13.43-7.6h10.34C661.94,411,654,416.82,641.38,416.82,624.39,416.82,615.36,406.24,615.36,386.28Zm40.75-5.35c-1.3-10.81-6.53-16.4-15.44-16.4s-14.15,5.59-15.45,16.4Z" style="fill:#373833"/><polygon points="105.12 429.87 179.13 385.56 105.12 341.26 115.51 324 201.41 375.33 201.41 395.8 115.51 447.13 105.12 429.87" style="fill:#29abe2"/><polygon points="119.25 395.8 119.25 375.33 205.22 323.97 215.55 341.26 141.53 385.56 215.55 429.87 205.16 447.13 119.25 395.8" style="fill:#0071bc;mix-blend-mode:multiply"/></g></g></g></g></svg>
            {% endif %}
          </div>
        {% endcapture %}
    {%- when 'title' -%}
			{% liquid
        assign title = block.settings.title 
				assign titleCustomFont = block.settings.title_custom_font
				assign titleFont = block.settings.title_font
        assign titleFontName = block.settings.title_font_name
        assign titleFontWeight = block.settings.title_font_weight
				assign titleColor = block.settings.title_color
				assign titleFontSize = block.settings.title_font_size
				assign titleFontSizeMobile = block.settings.title_font_size_mobile
				assign titleLineHeight = block.settings.title_line_height
				assign titleLineHeightMobile = block.settings.title_line_height_mobile
				assign titleLetterSpacing = block.settings.title_letter_spacing
				assign titleLetterSpacingMobile = block.settings.title_letter_spacing_mobile
				assign titleMarginTop = block.settings.title_margin_top
				assign titleMarginTopMobile = block.settings.title_margin_top_mobile
				assign titleMarginBottom = block.settings.title_margin_bottom
				assign titleMarginBottomMobile = block.settings.title_margin_bottom_mobile
			%}
      {% capture titleElement %}
        <div class="qq-title">{{title}}</div>
      {% endcapture %}
    {%- when 'subtitle' -%}
			{% liquid
        assign subtitle = block.settings.subtitle			
				assign subtitleCustomFont = block.settings.subtitle_custom_font
				assign subtitleFont = block.settings.subtitle_font
        assign subtitleFontName = block.settings.subtitle_font_name
        assign subtitleFontWeight = block.settings.subtitle_font_weight
				assign subtitleColor = block.settings.subtitle_color
				assign subtitleFontSize = block.settings.subtitle_font_size
				assign subtitleFontSizeMobile = block.settings.subtitle_font_size_mobile
				assign subtitleLineHeight = block.settings.subtitle_line_height
				assign subtitleLineHeightMobile = block.settings.subtitle_line_height_mobile
				assign subtitleLetterSpacing = block.settings.subtitle_letter_spacing
				assign subtitleLetterSpacingMobile = block.settings.subtitle_letter_spacing_mobile
				assign subtitleMarginTop = block.settings.subtitle_margin_top
				assign subtitleMarginTopMobile = block.settings.subtitle_margin_top_mobile
				assign subtitleMarginBottom = block.settings.subtitle_margin_bottom
				assign subtitleMarginBottomMobile = block.settings.subtitle_margin_bottom_mobile
			%}
      {% capture subtitleElement %}
        <div class="qq-subtitle">{{subtitle}}</div>
      {% endcapture %}
    {%- when 'textblock' -%}
			{% liquid        
				assign textblockCustomFont = block.settings.textblock_custom_font
				assign textblockFont = block.settings.textblock_font
        assign textblockFontName = block.settings.textblock_font_name
        assign textblockFontWeight = block.settings.textblock_font_weight
				assign textblockColor = block.settings.textblock_color
				assign textblockFontSize = block.settings.textblock_font_size
				assign textblockFontSizeMobile = block.settings.textblock_font_size_mobile
				assign textblockLineHeight = block.settings.textblock_line_height
				assign textblockLineHeightMobile = block.settings.textblock_line_height_mobile
				assign textblockLetterSpacing = block.settings.textblock_letter_spacing
				assign textblockLetterSpacingMobile = block.settings.textblock_letter_spacing_mobile
        assign textblockMarginTop = block.settings.textblock_margin_top
				assign textblockMarginTopMobile = block.settings.textblock_margin_top_mobile
				assign textblockMarginBottom = block.settings.textblock_margin_bottom
				assign textblockMarginBottomMobile = block.settings.textblock_margin_bottom_mobile
			%}
      {% capture textblockElement %}
        <div class="qq-rte">
          {{ block.settings.textblock }}
        </div>
      {% endcapture %}
    {%- when 'buttons' -%}
			{% liquid
          assign buttonUrl = block.settings.button_link
          assign buttonLabel = block.settings.button_label
          assign buttonClass = block.settings.button_class
          assign buttonCustomFont = block.settings.button_custom_font
          assign buttonFont = block.settings.button_font
          assign buttonFontName = block.settings.button_font_name
          assign buttonFontWeight = block.settings.button_font_weight
          assign buttonMaxWidth = block.settings.button_max_width
          assign buttonFontSize = block.settings.button_font_size
          assign buttonPaddingHorizontal = block.settings.button_padding_horizontal
          assign buttonPaddingVertical =  block.settings.button_padding_vertical
          assign buttonBorder = block.settings.button_border
          assign buttonRadius = block.settings.button_radius
          assign buttonBackground = block.settings.button_background_color
          assign buttonBackgroundHover = block.settings.button_background_color_hover
          assign buttonColor = block.settings.button_text_color
          assign buttonColorHover = block.settings.button_text_color_hover
          assign buttonBorderColor = block.settings.button_border_color
          assign buttonBorderColorHover = block.settings.button_border_color_hover
          assign buttonLetterSpacing = block.settings.button_letter_spacing
          assign buttonLetterSpacingMobile = block.settings.button_letter_spacing_mobile
          assign buttonMarginTop = block.settings.button_margin_top
          assign buttonMarginTopMobile = block.settings.button_margin_top_mobile
          assign buttonMarginBottom = block.settings.button_margin_bottom
          assign buttonMarginBottomMobile = block.settings.button_margin_bottom_mobile
          if block.settings.button_tab
            assign buttonTab = 'target="blank"'
          else
            assign buttonTab = ''
          endif
          assign buttonUrl_2 = block.settings.button_link_2
          assign buttonLabel_2 = block.settings.button_label_2
          assign buttonClass_2 = block.settings.button_class_2
          assign buttonCustomFont_2 = block.settings.button_custom_font_2
          assign buttonFont_2 = block.settings.button_font_2
          assign buttonFontName_2 = block.settings.button_font_name_2
          assign buttonFontWeight_2 = block.settings.button_font_weight_2
          assign buttonMaxWidth_2 = block.settings.button_max_width_2
          assign buttonFontSize_2 = block.settings.button_font_size_2
          assign buttonFontSizeMobile_2 = block.settings.button_font_size_mobile_2
          assign buttonPaddingHorizontal_2 = block.settings.button_padding_horizontal_2
          assign buttonPaddingVertical_2 =  block.settings.button_padding_vertical_2
          assign buttonBorder_2 = block.settings.button_border_2
          assign buttonRadius_2 = block.settings.button_radius_2
          assign buttonBackground_2 = block.settings.button_background_color_2
          assign buttonBackgroundHover_2 = block.settings.button_background_color_hover_2
          assign buttonColor_2 = block.settings.button_text_color_2
          assign buttonColorHover_2 = block.settings.button_text_color_hover_2
          assign buttonBorderColor_2 = block.settings.button_border_color_2
          assign buttonBorderColorHover_2 = block.settings.button_border_color_hover_2
          assign buttonLetterSpacing_2 = block.settings.button_letter_spacing_2
          assign buttonLetterSpacingMobile_2 = block.settings.button_letter_spacing_mobile_2
          assign buttonMarginTop_2 = block.settings.button_margin_top_2
          assign buttonMarginTopMobile_2 = block.settings.button_margin_top_mobile_2
          assign buttonMarginBottom_2 = block.settings.button_margin_bottom_2
          assign buttonMarginBottomMobile_2 = block.settings.button_margin_bottom_mobile_2
          if block.settings.button_tab_2
            assign buttonTab_2 = 'target="blank"'
          else
            assign buttonTab_2 = ''
          endif
			%}
        {% capture buttonElement %}
          <a href="{{buttonUrl}}" class="qq-btn {{buttonClass}} qq-el-1" {{buttonTab}}>{{ buttonLabel | escape }}</a>
        {% endcapture %}
         {% capture buttonElement_2 %}
          {% if buttonLabel_2 != blank %}
              <a href="{{buttonUrl_2}}" class="qq-btn {{buttonClass_2}} qq-el-2" {{buttonTab_2}}>{{ buttonLabel_2 | escape }}</a>
          {% endif %}
        {% endcapture %}
    {%- when 'video' -%}
      {% capture videoElement %}
        {% liquid
          assign blockVideo = true
          assign externalVideo = block.settings.video_url
          assign localVideo = block.settings.local_video_url
          assign posterImage = block.settings.poster_image
          assign playIcon = block.settings.video_icon
          assign playIconSize = block.settings.video_icon_size
          assign videoAutoplay = block.settings.video_autoplay
          assign videoLoop = block.settings.video_loop
          assign videoControls = block.settings.video_controls
          assign videoDimensions = block.settings.video_dimensions
          assign videoPosition = block.settings.video_position
          assign videoPositionMobile = block.settings.video_position_mobile
          if videoPosition == 'right'
            assign blocksOrderVideo = 'qq-row'
          elsif videoPosition == 'left'
            assign blocksOrderVideo = 'qq-row-reverse'
          endif
          if videoPositionMobile == 'top'
            assign blocksOrderVideoMobile = 'qq-column-reverse'
          elsif videoPositionMobile == 'bottom'
            assign blocksOrderVideoMobile = 'qq-column'
          elsif videoPositionMobile == 'hidden'
            assign blocksOrderVideoMobile = 'qq-column'
            assign videoClass = 'qq-hidden-on-mobile'
          endif
          if posterImage
            assign posterImageUrl = posterImage | img_url: '900x375'
          endif
          if playIcon != blank
            assign iconClass = playIconSize
            assign playIconUrl = playIcon | img_url: '300x125'
          else
            assign iconClass = playIconSize | append: ' qq-default'
          endif
          if externalVideo != blank or localVideo != blank
            assign divClass = 'qq-responsive-video-container '
            assign blockVideo = true
          else
            assign divClass = ''
            assign blockVideo = false
          endif
        %}
        {% if posterImage != blank %}
          {% assign coverID = 'qq-video-cover-' | append: section.id %}
          {% assign videoID = 'qq-video-' | append: section.id  %}
          <div id="{{coverID}}" data-vidID="{{videoID}}" class="qq-video-cover" onclick="" style="background-image:url('{{posterImageUrl}}')">
            <a href="#" class="qq-play-icon qq-{{iconClass}}" {% if playIconUrl != blank %}style="background-image:url('{{ playIconUrl }}');"{% endif %}></a>
          </div>
        {% endif %}
        <div class="{{divClass}}{{videoClass}} qq-{{videoDimensions}}">
            {% if localVideo != blank %}
              {% liquid
                if posterImage != blank
                  assign videoAttributes = ''
                else
                  if videoAutoplay == true
                    assign videoAttributes = ' muted="" autoplay'
                  else
                    assign videoAttributes = ''
                  endif
                endif
                if videoControls == true
                  assign videoAttributes = videoAttributes | append: ' controls'
                endif
                if videoLoop == true
                  assign videoAttributes = videoAttributes | append: ' loop'
                endif
                for vid in localVideo.sources
                  if vid.format == 'mp4'
                    assign localVideoUrl = vid.url
                    assign localVideoMime = vid.mime_type
                    break
                  endif
                endfor
              %}
              <video
                {{videoAttributes}}
                playsinline="true"
                preload="{{vid_preload}}"
                class="qq-local"
                id="{{videoID}}">
                  <source src="{{ localVideoUrl }}" type="{{ localVideoMime }}">
              </video>
            {% else %}
              {% if externalVideo %}
                {% if externalVideo.type == 'youtube' %}
                  {% liquid
                    if posterImage != blank
                      assign videoAttributes = ''
                    else
                      if videoAutoplay == true
                        assign videoAttributes = '&autoplay=1&mute=1'
                      else
                        assign videoAttributes = ''
                      endif
                    endif
                    if videoControls == false
                      assign videoAttributes = videoAttributes | append: '&controls=0&modestbranding=1&showinfo=0&showsearch=0'
                    endif
                    if videoLoop == true
                      assign videoAttributes = videoAttributes | append: '&loop=1&playlist=' | append: externalVideo.id
                    endif
                  %}
                  <div class="qq-video-wrapper">
                    <iframe class="youtube" src="//www.youtube.com/embed/{{ externalVideo.id }}?rel=0&amp;showinfo=0{{videoAttributes}}&iv_load_policy=3" frameborder="0" allowfullscreen  {{ block.shopify_attributes }} {% unless request.design_mode == true %}loading="lazy"{% endunless %}></iframe>
                  </div>
                {% elsif externalVideo.type == 'vimeo' %}
                  {% liquid
                    if posterImage != blank
                      assign videoAttributes = ''
                    else
                      if videoAutoplay == true
                        assign videoAttributes = '&autoplay=1&muted=1'
                      else
                        assign videoAttributes = ''
                      endif
                    endif
                    if videoControls == false
                      assign videoAttributes = videoAttributes | append: '&controls=0'
                    endif
                    if videoLoop == true
                      assign videoAttributes = videoAttributes | append: '&loop=1'
                    endif
                  %}
                  <iframe class="vimeo" src="//player.vimeo.com/video/{{ externalVideo.id }}?{{videoAttributes}}" width="500" height="232" frameborder="0" webkitallowfullscreen mozallowfullscreen allowfullscreen  {{ block.shopify_attributes }} loading="lazy"></iframe>
                {% endif %}
              {% else %}
