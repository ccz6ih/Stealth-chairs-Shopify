<div class="qq-section-wrap-{{sectionWidth}} {{sectionClass}}">
  <div class="qq-split-sections
    {% if blocksOrderVideo%}
      {{blocksOrderVideo}} {{blocksOrderVideoMobile}}
    {%else%}
      {{blocksOrder}} {{blocksOrderMobile}}
    {%endif%}
    {%if section.blocks.size > 1%}qq-grid{%endif%}">
    <div class="qq-section-content">
      <div>
        {% assign buttonCounter = 1 %}        
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'title' -%}
               {{titleElement}}
            {%- when 'subtitle' -%}
               {{subtitleElement}}
            {%- when 'textblock' -%}
               {{textblockElement}}
            {%- when 'buttons' -%}
              <div class="qq-button-wrapper" style="display:flex;">
                  {{buttonElement}} {% if buttonElement_2 %}{{buttonElement_2}}{%endif%}
              </div>           
          {% endcase %}
        {% endfor %}
      </div>
    </div>
    {% if imageElement or videoElement %}
      {% liquid
        if videoElement
          assign sectionClass = 'qq-section-video'
        else
          if imageElement
            assign sectionClass = 'qq-section-image'
          endif
        endif
      %}
      <div class="{{sectionClass}}">
        {% if videoElement %}
          {{videoElement}}
        {% else %}
          {{imageElement}}
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
