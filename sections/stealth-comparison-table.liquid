<div class="stealth-compare color-{{ section.settings.color_scheme }} gradient">
  <div class="stealth-compare__inner page-width">
    {%- if section.settings.heading != blank -%}
      <div class="stealth-compare__header">
        {%- if section.settings.subheading != blank -%}
          <span class="stealth-compare__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        <h2 class="stealth-compare__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="stealth-compare__table-wrap">
      <table class="stealth-compare__table">
        <thead>
          <tr>
            <th class="stealth-compare__feature-col">Feature</th>
            {%- for block in section.blocks -%}
              {%- if block.type == 'brand_column' -%}
                <th class="stealth-compare__brand-col {% if block.settings.is_stealth %}stealth-compare__brand-col--highlight{% endif %}" {{ block.shopify_attributes }}>
                  <span class="stealth-compare__brand-name">{{ block.settings.brand_name }}</span>
                  {%- if block.settings.price != blank -%}
                    <span class="stealth-compare__brand-price">{{ block.settings.price }}</span>
                  {%- endif -%}
                </th>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- assign feature_blocks = section.blocks | where: 'type', 'feature_row' -%}
          {%- for block in feature_blocks -%}
            <tr {{ block.shopify_attributes }}>
              <td class="stealth-compare__feature-name">
                {{ block.settings.feature_name }}
                {%- if block.settings.feature_detail != blank -%}
                  <span class="stealth-compare__feature-detail">{{ block.settings.feature_detail }}</span>
                {%- endif -%}
              </td>
              <td class="stealth-compare__cell stealth-compare__cell--highlight">
                {%- if block.settings.col_1_value == 'yes' -%}
                  <span class="stealth-compare__check" aria-label="Yes">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                {%- elsif block.settings.col_1_value == 'no' -%}
                  <span class="stealth-compare__cross" aria-label="No">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- else -%}
                  <span class="stealth-compare__text-val">{{ block.settings.col_1_text }}</span>
                {%- endif -%}
              </td>
              <td class="stealth-compare__cell">
                {%- if block.settings.col_2_value == 'yes' -%}
                  <span class="stealth-compare__check" aria-label="Yes">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                {%- elsif block.settings.col_2_value == 'no' -%}
                  <span class="stealth-compare__cross" aria-label="No">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- else -%}
                  <span class="stealth-compare__text-val">{{ block.settings.col_2_text }}</span>
                {%- endif -%}
              </td>
              <td class="stealth-compare__cell">
                {%- if block.settings.col_3_value == 'yes' -%}
                  <span class="stealth-compare__check" aria-label="Yes">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                {%- elsif block.settings.col_3_value == 'no' -%}
                  <span class="stealth-compare__cross" aria-label="No">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- else -%}
                  <span class="stealth-compare__text-val">{{ block.settings.col_3_text }}</span>
                {%- endif -%}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="stealth-compare__cta">
        <a href="{{ section.settings.button_link }}" class="button button--primary">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .stealth-compare {
    padding: 4rem 0;
  }

  .stealth-compare__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .stealth-compare__subheading {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-button);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .stealth-compare__heading {
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    margin: 0;
  }

  .stealth-compare__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .stealth-compare__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .stealth-compare__table thead th {
    padding: 1.25rem 1rem;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid rgba(255,255,255,0.1);
  }

  .stealth-compare__feature-col {
    text-align: left !important;
    width: 30%;
  }

  .stealth-compare__brand-col {
    width: 23.3%;
  }

  .stealth-compare__brand-col--highlight {
    background: rgba(255,255,255,0.04);
    border-top: 3px solid var(--color-button);
  }

  .stealth-compare__brand-name {
    display: block;
    font-size: 1.1rem;
  }

  .stealth-compare__brand-price {
    display: block;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 0.25rem;
    font-weight: 400;
  }

  .stealth-compare__table tbody tr {
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.2s ease;
  }

  .stealth-compare__table tbody tr:hover {
    background: rgba(255,255,255,0.02);
  }

  .stealth-compare__feature-name {
    padding: 1rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .stealth-compare__feature-detail {
    display: block;
    font-weight: 400;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 0.2rem;
  }

  .stealth-compare__cell {
    padding: 1rem;
    text-align: center;
    font-size: 0.9rem;
  }

  .stealth-compare__cell--highlight {
    background: rgba(255,255,255,0.02);
  }

  .stealth-compare__check {
    color: var(--color-button);
  }

  .stealth-compare__cross {
    opacity: 0.3;
  }

  .stealth-compare__text-val {
    font-size: 0.85rem;
  }

  .stealth-compare__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media screen and (max-width: 749px) {
    .stealth-compare {
      padding: 3rem 0;
    }

    .stealth-compare__table {
      font-size: 0.85rem;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth Compare Table",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW STEALTH COMPARES"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "brand_column",
      "name": "Brand Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "default": "Stealth"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price range"
        },
        {
          "type": "checkbox",
          "id": "is_stealth",
          "label": "Highlight as Stealth column",
          "default": false
        }
      ]
    },
    {
      "type": "feature_row",
      "name": "Feature Row",
      "settings": [
        {
          "type": "text",
          "id": "feature_name",
          "label": "Feature name",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "feature_detail",
          "label": "Feature detail"
        },
        {
          "type": "select",
          "id": "col_1_value",
          "label": "Column 1 value",
          "options": [
            { "value": "yes", "label": "Check" },
            { "value": "no", "label": "Cross" },
            { "value": "text", "label": "Custom text" }
          ],
          "default": "yes"
        },
        {
          "type": "text",
          "id": "col_1_text",
          "label": "Column 1 custom text"
        },
        {
          "type": "select",
          "id": "col_2_value",
          "label": "Column 2 value",
          "options": [
            { "value": "yes", "label": "Check" },
            { "value": "no", "label": "Cross" },
            { "value": "text", "label": "Custom text" }
          ],
          "default": "no"
        },
        {
          "type": "text",
          "id": "col_2_text",
          "label": "Column 2 custom text"
        },
        {
          "type": "select",
          "id": "col_3_value",
          "label": "Column 3 value",
          "options": [
            { "value": "yes", "label": "Check" },
            { "value": "no", "label": "Cross" },
            { "value": "text", "label": "Custom text" }
          ],
          "default": "no"
        },
        {
          "type": "text",
          "id": "col_3_text",
          "label": "Column 3 custom text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stealth Compare Table",
      "blocks": [
        { "type": "brand_column", "settings": { "brand_name": "Stealth", "price": "From $599", "is_stealth": true } },
        { "type": "brand_column", "settings": { "brand_name": "Herman Miller", "price": "From $1,395" } },
        { "type": "brand_column", "settings": { "brand_name": "Generic Studio", "price": "From $300" } },
        { "type": "feature_row", "settings": { "feature_name": "Designed for Music/AV Pros", "col_1_value": "yes", "col_2_value": "no", "col_3_value": "no" } },
        { "type": "feature_row", "settings": { "feature_name": "Patented Forward-Lean Tech", "feature_detail": "ZenWave motion technology", "col_1_value": "yes", "col_2_value": "no", "col_3_value": "no" } },
        { "type": "feature_row", "settings": { "feature_name": "Custom-Fit to Body Type", "col_1_value": "yes", "col_2_value": "text", "col_2_text": "Size options only", "col_3_value": "no" } },
        { "type": "feature_row", "settings": { "feature_name": "Built in USA", "col_1_value": "yes", "col_2_value": "text", "col_2_text": "Some models", "col_3_value": "no" } },
        { "type": "feature_row", "settings": { "feature_name": "5-Year Warranty", "col_1_value": "yes", "col_2_value": "text", "col_2_text": "12 years", "col_3_value": "text", "col_3_text": "1-3 years" } },
        { "type": "feature_row", "settings": { "feature_name": "Stage-Rated Casters", "col_1_value": "yes", "col_2_value": "no", "col_3_value": "no" } }
      ]
    }
  ]
}
{% endschema %}
