{%- style -%}
  .scrolling-text-section .grid {
      display: flex;
      flex-wrap: wrap;
      padding: 0;
      list-style: none;
      column-gap: 0;
      row-gap: 0;
  }

  .scrolling-text-section.section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }} .scrolling-text-inner * {
      font-size: {{ section.settings.scrolling_text_size }}px;
      line-height: {{ section.settings.scrolling_text_line_height }}px;
  }

  .scrolling-text-section .grid__item {
      padding: 0 30px;
  }

  .scrolling-text-section .scrolling-text-item {
      padding-top: 50px;
      padding-bottom: 50px;
  }

  .scrolling-with-text__text-item .button::before, .scrolling-with-text__text-item .button::after {
      display: none;
  }

  .scrolling-with-text__text.rte {
      margin-bottom: 30px;
  }

  .scrolling-with-text__content {
      align-items: center;
      display: flex;
      height: 100%;
  }

  .scrolling-with-text__text-item {
  	position: relative;
  }

  .scrolling-with-text__image img {
  	width: 100%;
  	height: 100%;
  	object-fit: cover;
  }

  .scrolling-with-text__image {
  	width: 100%;
  	display: block;
  	height: 100%;
      line-height: 0;
  }

  .scrolling-text-inner {
      max-height: 640px;
      overflow: hidden;
      -webkit-mask-image: linear-gradient(0deg,transparent 0,#000 20%,#000 70%,transparent);
      mask-image: linear-gradient(180deg,transparent 0,#000 20%,#000 70%,transparent);
  }

  .scrolling-with-text__heading {
      margin: 0 0 20px;
  }

  .scrolling-text-vetical {
      animation: vertTicker {{ section.settings.scrolling_text_speed }}s linear infinite forwards;
  }

  @keyframes vertTicker {
      to {
          transform: translateY(-50%);
      }
  }

  .scrolling-with-text__heading.h2 {
      font-size: 24px;
      line-height: 34px;
  }

  .scrolling-with-text__heading.h1 {
      font-size: 36px;
      line-height: 46px;
  }

  .scrolling-with-text__heading.h0 {
      font-size: 58px;
      line-height: 68px;
  }

  .scrolling-with-text__text-subtitle * {
      font-size: 22px;
      line-height: 30px;
  }

  .scrolling-text-vetical p {
      margin: 0;
  }

  .scrolling-text-section .grid--2-col-tablet .grid__item {
      width: 100%;
      max-width: 100%;
  }

  .scrolling-with-text__content .button {
      padding: 15px 30px;
      text-decoration: none;
      font-size: 16px;
      line-height: 20px;
  }

  .scrolling-with-text__text-item.text-bg-image {
  	padding: 0;
  }

  .text-bg-image .scrolling-with-text__content {
  	position: absolute;
  	top: 0;
  	right: 0;
  	bottom: 0;
  	left: 0;
  	padding: 0 30px;
  }

  .scrolling-text-item {
  	display: flex;
  	align-items: center;
  	justify-content: center;
  }

  .scrolling-with-text__content-inner {
  	margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
      }
      .scrolling-text__grid--reverse {
          flex-direction: row-reverse;
      }
      .scrolling-text-section .grid--2-col-tablet .grid__item {
          width: 50%;
          max-width: 50%;
      }
  }

  @media screen and (max-width: 749px) {
      .scrolling-text-inner {
          max-height: 400px;
      }
      .scrolling-text-section .grid {
          flex-direction: column-reverse;
      }
      .scrolling-with-text__content {
          padding: 35px 0;
      }
      .scrolling-text-section .scrolling-text-item {
          padding-top: 35px;
          padding-bottom: 35px;
      }
      .section-{{ section.id }} .scrolling-text-inner * {
          font-size: {{ section.settings.mobile_scrolling_text_size }}px;
          line-height: {{ section.settings.mobile_scrolling_text_line_height }}px;
      }
      .scrolling-with-text__heading.h1 {
          font-size: 30px;
          line-height: 40px;
      }
      .scrolling-with-text__heading.h0 {
          font-size: 44px;
          line-height: 54px;
      }
      .scrolling-with-text__text-subtitle * {
          font-size: 20px;
          line-height: 28px;
      }
      .scrolling-with-text__heading {
      	margin: 0 0 7px;
      }
      .scrolling-with-text__text.rte {
      	margin-bottom: 10px;
      }
      .text-bg-image .scrolling-with-text__content {
      	padding: 0px 15px;
      }
      .scrolling-with-text__image img {
      	position: absolute;
      	top: 0;
      	bottom: 0;
      	left: 0;
      	right: 0;
      }
      .scrolling-with-text__image {
      	height: auto;
      	padding-top: 100%;
      }
      .scrolling-with-text__image.scrolling-with-text__image-small {
      	padding-top: 75%;
      }
      .scrolling-with-text__image.scrolling-with-text__image-large {
      	padding-top: 125%;
      }
  }

  .jewel-gradient-text-1 {
      background: linear-gradient(45deg, #d32f2f, #7b1fa2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
  }

  .jewel-gradient-text-2 {
      background: linear-gradient(45deg, #1976d2, #388e3c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
  }

  .jewel-gradient-text-3 {
      background: linear-gradient(45deg, #fbc02d, #f57c00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
  }
{%- endstyle -%}

<div class="scrolling-text-section section-{{ section.id }}">
  <div class="grid grid--2-col-tablet {% if section.settings.layout == 'text_first' %} scrolling-text__grid--reverse{% endif %}">
    <div class="scrolling-text-item grid__item" style="background:{{ section.settings.scrolling_text_bg_color }};">
      {% if section.settings['scrolling-text'] != blank %}
        <div
          class="scrolling-text-inner"
          style="color:{{ section.settings.scrolling_text_color }}; text-align:{{ section.settings.scrolling_text_align }}; text-transform: {{ section.settings.scrolling_text_transform }};"
        >
          <div class="scrolling-text-vetical">
            <p class="jewel-gradient-text-1">{{ section.settings['scrolling-text'] }}</p>
            <p class="jewel-gradient-text-2">{{ section.settings['scrolling-text'] }}</p>
            <p class="jewel-gradient-text-3">{{ section.settings['scrolling-text'] }}</p>
            <p class="jewel-gradient-text-1">{{ section.settings['scrolling-text'] }}</p>
          </div>
        </div>
      {% endif %}
    </div>
    <div class="scrolling-with-text__text-item grid__item{% if section.settings['image'] != blank %} text-bg-image{% endif %}">
      {% if section.settings.image != blank %}
        <div class="scrolling-with-text__image scrolling-with-text__image-{{ section.settings.mobile-image-size }}">
          <img
            src="{{ section.settings.image | img_url: 'master' }}"
            alt="{{ section.settings.image.alt }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        </div>
      {% endif %}
      <div class="scrolling-with-text__content">
        <div
          class="scrolling-with-text__content-inner"
          style="text-align: {{ section.settings.content_align }}; {% if section.settings.content_size == 'grid' %}max-width: 400px;{% endif %}"
        >
          {%- for block in section.blocks -%}
            {% case block.type %}
              {%- when 'heading' -%}
                <h2
                  class="scrolling-with-text__heading {{ block.settings.heading_size }}"
                  style="color:{{ block.settings.heading_color }}; text-transform: {{ block.settings.heading_transform }}"
                >
                  {{ block.settings.heading }}
                </h2>
              {%- when 'text' -%}
                <div
                  class="scrolling-with-text__text rte scrolling-with-text__text-{{ block.settings.text_style }}"
                  style="color:{{ block.settings.text_color }}"
                >
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link }}"
                    class="button"
                    style="background:{{ block.settings.btn_bg_color }}; color:{{ block.settings.btn_label_color }};"
                  >
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
"name": "Scrolling text",
"class": "section",
"settings": [
    {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
    },
    {
        "type": "select",
        "id": "mobile-image-size",
        "options": [
            {
                "value": "small",
                "label": "Small"
            },
            {
                "value": "medium",
                "label": "Medium"
            },
            {
                "value": "large",
                "label": "Large"
            }
        ],
        "default": "medium",
        "label": "Mobile image size"
    },
    {
        "type": "range",
        "id": "scrolling_text_speed",
        "min": 0,
        "max": 200,
        "step": 2,
        "unit": "s",
        "label": "Scrolling speed",
        "default": 100
    },
    {
        "type": "richtext",
        "id": "scrolling-text",
        "default": "<p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p><p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p><p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p><p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p>",
        "label": "Scrolling text"
    },

    {
        "type": "select",
        "id": "scrolling_text_align",
        "options": [
            {
                "value": "left",
                "label": "Left"
            },
            {
                "value": "center",
                "label": "Center"
            },
            {
                "value": "right",
                "label": "Right"
            }
        ],
        "default": "center",
        "label": "Scrolling text alignment"
    },

    {
        "type": "select",
        "id": "scrolling_text_transform",
        "options": [
            {
                "value": "uppercase",
                "label": "Uppercase"
            },
            {
                "value": "lowercase",
                "label": "Lowercase"
            },
            {
                "value": "capitalize",
                "label": "Capitalize"
            },
            {
                "value": "",
                "label": "Auto"
            }
        ],
        "default": "uppercase",
        "label": "Scrolling text transform"
    },
    {
        "type": "header",
        "content": "Desktop size"
    },
    {
        "type": "range",
        "id": "scrolling_text_size",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Scrolling text size",
        "default": 48
    },
    {
        "type": "range",
        "id": "scrolling_text_line_height",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Scrolling text line height",
        "default": 58
    },
    {
        "type": "header",
        "content": "Mobile size"
    },
    {
        "type": "range",
        "id": "mobile_scrolling_text_size",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Scrolling text size",
        "default": 30
    },
    {
        "type": "range",
        "id": "mobile_scrolling_text_line_height",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Scrolling text line height",
        "default": 40
    },
    {
        "type": "color",
        "id": "scrolling_text_color",
        "label": "Scrolling text color",
        "default": "#fff"
    },
    {
        "type": "color",
        "id": "scrolling_text_bg_color",
        "label": "Scrolling text background color",
        "default": "#000"
    },
    {
        "type": "select",
        "id": "layout",
        "options": [
            {
                "value": "scrolling_first",
                "label": "Scrolling first"
            },
            {
                "value": "text_first",
                "label": "Content first"
            }
        ],
        "default": "text_first",
        "label": "Layout"
    },
    {
        "type": "select",
        "id": "content_align",
        "options": [
            {
                "value": "left",
                "label": "Left"
            },
            {
                "value": "center",
                "label": "Center"
            },
            {
                "value": "right",
                "label": "Right"
            }
        ],
        "default": "center",
        "label": "Content alignment"
    },
    {
        "type": "select",
        "id": "content_size",
        "options": [
            {
                "value": "full",
                "label": "Full"
            },
            {
                "value": "grid",
                "label": "Grid"
            }
        ],
        "default": "full",
        "label": "Content size"
    },
    {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding top",
        "default": 0
    },
    {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom",
        "default": 0
