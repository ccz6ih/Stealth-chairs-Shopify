{% capture carouselArrows %}
    {% liquid
        assign arrowLeftImage = section.settings.arrow_left
        assign arrowLeftImageUrl = arrowLeftImage | img_url: '32x32', crop: 'center'
        if arrowLeftImage.alt != blank
            assign arrowLeftImageAlt = 'alt="' | append: arrowLeftImage.alt | append: '"'
        else
            assign arrowLeftImageAlt = ''
        endif
		if arrowLeftImageUrl != blank
			assign customLeft = 'qq-custom-left'
		else
			assign customLeft = ''
		endif
        assign arrowRightImage = section.settings.arrow_right
        assign arrowRightImageUrl = arrowRightImage | img_url: '32x32', crop: 'center'
        if arrowRightImage.alt != blank
            assign arrowRightImageAlt = 'alt="' | append: arrowRightImage.alt | append: '"'
        else
            assign arrowRightImageAlt = ''
        endif
		if arrowRightImageUrl != blank
			assign customRight = 'qq-custom-right'
		else
			assign customRight = ''
		endif
    %}
    <div class="qq-carousel-arrows qq-hidden">
        <span class="qq-carousel-arrow qq-carousel-prev {{customLeft}}">
            {% if arrowLeftSvg != blank %}
                <img src="{{arrowLeftSvg}}" loading="lazy">
            {% elsif arrowLeftImage != blank %}
                <img src="{{arrowLeftImageUrl}}" {{arrowLeftImageAlt}} loading="lazy">
            {% else %}
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><g><g><circle cx="12" cy="12" r="12" style="fill:#fff;"/><polyline points="14 6.17 8.6 11.57 14 16.97" style="fill:none; stroke:#000; stroke-linecap:round; stroke-miterlimit:8; stroke-width:2px;"/></g></g></svg>
            {% endif %}
        </span>
        <span class="qq-carousel-arrow qq-carousel-next {{customRight}}">
            {% if arrowRightSvg != blank %}
                <img src="{{arrowRightSvg}}" loading="lazy">
            {% elsif arrowRightImage != blank %}
                <img src="{{arrowRightImageUrl}}" {{arrowRightImageAlt}} loading="lazy">
            {% else %}
                <svg  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><g id="Layer_1-2"><g><circle cx="12" cy="12" r="12" style="fill:#fff;"/><polyline points="10 17.83 15.4 12.43 10 7.03" style="fill:none; stroke:#000; stroke-linecap:round; stroke-miterlimit:8; stroke-width:2px;"/></g></g></svg>
            {% endif %}
        </span>
    </div>
{% endcapture %}
{% capture sectionHeader %}
	{% if sectionTitle != blank or sectionTextblock != blank %}
		<div class="qq-video-gallery-header">
			{% if sectionTitle != blank %}
				<div class="qq-title">{{sectionTitle}}</div>
			{% endif %}
			{% if sectionTextblock != blank %}
				<div class="qq-textblock">{{sectionTextblock}}</div>
			{% endif %}
		</div>
	{% endif %}
{% endcapture %}
{% if sectionHeaderPosition == 'outside' %}
  {{sectionHeader}}
{% endif %}
<div class="qq-section-wrap-{{sectionWidth}} {{sectionClass}}" id="{{divID}}">
	{% if sectionHeaderPosition == 'inside' %}
      {{sectionHeader}}
    {% endif %}
	{% if blocksSize != 0 %}
		<div class="qq-videos-toggle">
			<a class="qq-hidden" data-expand="{{carouselExpand}}" data-collapse="{{carouselCollapse}}">{{carouselExpand}}</a>
		</div>
	{% endif %}
	<div class="qq-videos {% if carouselDefaultState == "grid" %}qq-expanded{% endif %}">
		<div class="qq-videos-wrapper"
			data-enableSlider="{{makeCarousel}}"
			data-numOfSlides="{{blocksSize}}"
			data-slidesToShow="{{slidesToShow}}"
			data-carouselSlideAll="{{carouselSlideAll}}"
			data-carouselAutoplay="{{carouselAutoplay}}"
			data-carouselSpeed="{{carouselSpeed}}"
			data-carouselCentermode="{{carouselOverflow}}"
			data-carouselInfinite="{{carouselInfinite}}"
			data-imageDimensions="{{videoImageSize}}"
			data-customImageHeight="{{videoImageCustomHeight}}"
			data-showArrows="{{showArrows}}"
			data-default="{{carouselDefaultState}}"
			data-video-playing="{{videoPlaying}}">
			{%- for block in section.blocks -%}				
				{% liquid
					assign localVideo = block.settings.local_video
					assign localVideoUrl = localVideo.sources[0].url
					assign localVideoMime = localVideo.sources[0].mime_type
					for vid in localVideo.sources
						if vid.format == 'mp4'
							assign localVideoUrl = vid.url
							assign localVideoMime = vid.mime_type
							break
						endif
					endfor					
					if localVideoUrl == blank
						assign externalVideoUrl = block.settings.video_url
						if externalVideoUrl != blank							
							if externalVideoUrl.type == 'vimeo'
								assign vimeoID = externalVideoUrl.id
								assign youtubeID = ''																
							elsif externalVideoUrl.type == 'youtube'
								assign vimeoID = ''
								assign youtubeID = externalVideoUrl.id								
							endif
							assign videoType = externalVideoUrl.type
						else
							assign vimeoID = ''
							assign youtubeID = ''
							assign videoType = ''
						endif						
					else 
						assign videoType = 'local'
					endif
					if block.settings.video_getvid_thumb == true and localVideo == blank and block.settings.video_url.type == 'youtube' or block.settings.video_url.type == 'vimeo' 
						if block.settings.video_url.type == 'youtube' 
							assign videoImage = "https://img.youtube.com/vi/" | append: block.settings.video_url.id | append: "/maxresdefault.jpg"
						elsif block.settings.video_url.type == 'vimeo' 
							assign videoImage = "https://vumbnail.com/" | append: block.settings.video_url.id | append: ".jpg"
						endif
						assign videoImageUrl = videoImage
						assign useYoutubeVimeoThumb = true
					else
						if localVideo != blank
							assign videoImage = localVideo.preview_image
						else
							assign videoImage = block.settings.video_image
						endif
						assign proportion = videoImage.aspect_ratio
						assign videoImgW = videoImage.width
						assign videoImgH = videoImage.height
						assign maxWidthAllowed = 500
						assign maxHeightAllowed = 1300
						if slidesToShow == 2
								assign maxWidthAllowed = 850
								assign maxHeightAllowed = 1300
						elsif slidesToShow == 3
								assign maxWidthAllowed = 550
								assign maxHeightAllowed = 850
						elsif slidesToShow == 4
								assign maxWidthAllowed = 450
								assign maxHeightAllowed = 650
						elsif slidesToShow == 5
								assign maxWidthAllowed = 350
								assign maxHeightAllowed = 500
						elsif slidesToShow == 6
								assign maxWidthAllowed = 280
								assign maxHeightAllowed = 450
						endif
						if proportion > 1
							# landscape
							assign mostW = maxWidthAllowed
							assign mostH = mostW | times: proportion
						elsif proportion < 1
							# portrait
							assign mostH = maxHeightAllowed
							assign mostW = mostH | times: proportion
						else
							# sqaure
							assign mostW = maxWidthAllowed
							assign mostH = mostW
						endif
						assign iw = videoImgW | at_most: mostW | round
						assign ih = videoImgH | at_most: mostH | round
						if videoImageSize == 'portrait'
							assign ih = iw | divided_by: 0.6666667 | round
							if videoImgH < ih
								assign ih = videoImgH
								assign iw = ih | divided_by: 1.5 | round
							endif
							if videoImgW < iw
								assign iw = videoImgW
								assign ih = iw | divided_by: 0.666667 | round
							endif
						elsif videoImageSize == 'square'
							assign ih = iw
							if iw > videoImgW
								assign iw = videoImgW
								assign ih = iw
							endif
							if ih > videoImgH
								assign ih = videoImgH
								assign iw = ih
							endif
						elsif videoImageSize == 'landscape'
							assign ih = iw | divided_by: 1.5 | round
							if videoImgH < ih
								assign ih = videoImgH
								assign iw = ih | divided_by: 0.666667 | round
							endif
							if videoImgW < iw
								assign iw = videoImgW
								assign ih = iw | divided_by: 1.5 | round
							endif
						elsif videoImageSize == 'original'
							assign ih = iw | divided_by: proportion | round
						endif
						assign size = iw | append: 'x' | append: ih
						assign videoImageUrl = videoImage | img_url: size, crop: 'center'
					endif
					if videoImage.alt != blank
						assign videoImageAlt = 'alt="' | append: videoImage.alt | append: '"'
					else
						assign videoImageAlt = ''
					endif
					if videoPlaying == 'popup'
						assign videoDimensions = block.settings.video_dimensions
					endif
					assign videoTitle = block.settings.title 
					assign videoSubtitle = block.settings.video_subtitle 
					if videoType != 'local'
						if loopVideo == true 
							assign externalLoop = '?loop=1'
						else 
					endif
					endif 
				%}
				<div class="qq-single-video"
				data-slide-id="{{forloop.index0}}">						
					<a class="qq-video-thumb"										
					data-slide="{{forloop.index}}"
					data-autoplay="{{videoAutoplay}}"
					data-loop-video="{{videoLoop}}"
					data-show-controls="{{videoControls}}"										
					data-orientation="qq-{{videoDimensions}}"						
					data-local-video="{{localVideoUrl}}"
					data-local-video-mime="{{localVideoMime}}"
					data-youtube-video="{{youtubeID}}" 
					data-vimeo-video="{{vimeoID}}">
						{% if videoImage != blank %}
							<img src="{{videoImageUrl}}" {{videoImageAlt}} class="qq-video-image {% if useYoutubeVimeoThumb == true %}qq-yt-{{videoImageSize}}{% endif %}"  loading="lazy">
						{% else %}
