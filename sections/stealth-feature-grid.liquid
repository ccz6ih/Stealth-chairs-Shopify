<div class="stealth-features color-{{ section.settings.color_scheme }} gradient">
  <div class="stealth-features__inner page-width">
    {%- if section.settings.heading != blank -%}
      <div class="stealth-features__header">
        {%- if section.settings.subheading != blank -%}
          <span class="stealth-features__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        <h2 class="stealth-features__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p class="stealth-features__intro">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="stealth-features__grid stealth-features__grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="stealth-feature-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="stealth-feature-item__image">
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title }}"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}"
              >
            </div>
          {%- elsif block.settings.icon != 'none' -%}
            <div class="stealth-feature-item__icon">
              {%- case block.settings.icon -%}
                {%- when 'wave' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12c0-3 2.5-6 6-6s4 3 4 6-2.5 6-4 6"/><path d="M22 12c0-3-2.5-6-6-6s-4 3-4 6 2.5 6 4 6"/></svg>
                {%- when 'spine' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4m0 4v4m0 4v4"/><circle cx="12" cy="4" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="20" r="2"/><path d="M8 6h8M8 14h8M8 22h8"/></svg>
                {%- when 'shield' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                {%- when 'cog' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                {%- when 'ruler' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 3H3v18h18V3z"/><path d="M3 9h4"/><path d="M3 15h4"/><path d="M9 3v4"/><path d="M15 3v4"/></svg>
                {%- when 'star' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endcase -%}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="stealth-feature-item__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="stealth-feature-item__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .stealth-features {
    padding: 4rem 0;
  }

  .stealth-features__header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .stealth-features__subheading {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-button);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .stealth-features__heading {
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    margin: 0;
  }

  .stealth-features__intro {
    font-size: 1rem;
    opacity: 0.7;
    line-height: 1.6;
    margin: 1rem 0 0;
  }

  .stealth-features__grid {
    display: grid;
    gap: 1.5rem;
  }

  .stealth-features__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .stealth-features__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .stealth-features__grid--4 { grid-template-columns: repeat(4, 1fr); }

  .stealth-feature-item {
    padding: 2rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .stealth-feature-item:hover {
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-2px);
  }

  .stealth-feature-item__image {
    margin-bottom: 1.25rem;
    border-radius: 4px;
    overflow: hidden;
  }

  .stealth-feature-item__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .stealth-feature-item__icon {
    color: var(--color-button);
    margin-bottom: 1rem;
  }

  .stealth-feature-item__title {
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem;
  }

  .stealth-feature-item__text {
    font-size: 0.9rem;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .stealth-features__grid--3,
    .stealth-features__grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .stealth-features {
      padding: 3rem 0;
    }

    .stealth-features__grid--2,
    .stealth-features__grid--3,
    .stealth-features__grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth Feature Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PATENTED TECHNOLOGY"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (if no image)",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "wave", "label": "Wave / ZenWave" },
            { "value": "spine", "label": "Spine / Ergonomic" },
            { "value": "shield", "label": "Shield / Warranty" },
            { "value": "cog", "label": "Cog / Engineering" },
            { "value": "ruler", "label": "Ruler / Custom Fit" },
            { "value": "star", "label": "Star / Premium" }
          ],
          "default": "wave"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stealth Feature Grid",
      "blocks": [
        { "type": "feature", "settings": { "icon": "wave", "title": "ZenWave Motion", "text": "Patented technology that pivots the seat shell as you lean forward, maintaining healthy spinal alignment in every position." } },
        { "type": "feature", "settings": { "icon": "spine", "title": "Free-Float Backrest", "text": "The backrest follows your movement rather than fighting it — supporting your spine whether you're reclined or leaning into the mix." } },
        { "type": "feature", "settings": { "icon": "ruler", "title": "Custom-Fit Build", "text": "Every Stealth is built to your height and weight, with the right cylinder height, mesh tension, and seat size for your body." } }
      ]
    }
  ]
}
{% endschema %}
