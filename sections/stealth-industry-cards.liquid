<div class="stealth-industries color-{{ section.settings.color_scheme }} gradient">
  <div class="stealth-industries__inner page-width">
    {%- if section.settings.heading != blank -%}
      <div class="stealth-industries__header">
        {%- if section.settings.subheading != blank -%}
          <span class="stealth-industries__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        <h2 class="stealth-industries__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="stealth-industries__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="stealth-industry-card" {{ block.shopify_attributes }}>
          <div class="stealth-industry-card__icon">
            {%- case block.settings.icon -%}
              {%- when 'studio' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16V8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M6 12h.01"/><path d="M10 12h.01"/><path d="M14 12h.01"/><path d="M18 12h.01"/><path d="M6 16h.01"/><path d="M10 16h.01"/><path d="M14 16h.01"/><path d="M18 16h.01"/><rect x="1" y="18" width="22" height="3" rx="1"/></svg>
              {%- when 'live_sound' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              {%- when 'broadcast' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
              {%- when 'lighting' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- when 'performer' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="stealth-industry-card__title">{{ block.settings.title }}</h3>
          <p class="stealth-industry-card__text">{{ block.settings.text }}</p>
          <span class="stealth-industry-card__link">
            Learn More
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .stealth-industries {
    padding: 4rem 0;
  }

  .stealth-industries__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .stealth-industries__subheading {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-button);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .stealth-industries__heading {
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    margin: 0;
  }

  .stealth-industries__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  .stealth-industry-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .stealth-industry-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-button);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .stealth-industry-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .stealth-industry-card:hover::before {
    transform: scaleX(1);
  }

  .stealth-industry-card__icon {
    color: var(--color-button);
    margin-bottom: 1rem;
    transition: transform 0.3s ease;
  }

  .stealth-industry-card:hover .stealth-industry-card__icon {
    transform: scale(1.1);
  }

  .stealth-industry-card__title {
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem;
  }

  .stealth-industry-card__text {
    font-size: 0.85rem;
    opacity: 0.7;
    line-height: 1.5;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .stealth-industry-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-button);
    transition: gap 0.3s ease;
  }

  .stealth-industry-card:hover .stealth-industry-card__link {
    gap: 0.75rem;
  }

  @media screen and (max-width: 749px) {
    .stealth-industries {
      padding: 3rem 0;
    }

    .stealth-industries__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stealth-industry-card {
      padding: 1.5rem 1rem;
    }

    .stealth-industry-card__icon svg {
      width: 32px;
      height: 32px;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth Industry Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "WHO WE SERVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT FOR YOUR WORLD"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Industry Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "studio", "label": "Studio / Console" },
            { "value": "live_sound", "label": "Live Sound / Music" },
            { "value": "broadcast", "label": "Broadcast / Video" },
            { "value": "lighting", "label": "Lighting / Stage" },
            { "value": "performer", "label": "Performer / Mic" }
          ],
          "default": "studio"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Recording Studios"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "14-hour sessions demand more than an office chair."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stealth Industry Cards",
      "blocks": [
        { "type": "card", "settings": { "icon": "studio", "title": "Recording Studios", "text": "Mix, master, and produce in comfort — built for the forward lean at the console." } },
        { "type": "card", "settings": { "icon": "live_sound", "title": "Live Sound & FOH", "text": "From soundcheck to encore — Stage Glide casters and tour-tested durability." } },
        { "type": "card", "settings": { "icon": "broadcast", "title": "Video & Broadcast", "text": "Control room precision meets all-day comfort for broadcast and post-production." } },
        { "type": "card", "settings": { "icon": "lighting", "title": "Lighting & Stage", "text": "Programming marathons and tech tables — designed for elevated platforms." } },
        { "type": "card", "settings": { "icon": "performer", "title": "Performers", "text": "Play longer, sit better — a performance seat that supports your craft." } }
      ]
    }
  ]
}
{% endschema %}
