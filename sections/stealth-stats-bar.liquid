<div class="stealth-stats color-{{ section.settings.color_scheme }} gradient">
  <div class="stealth-stats__inner page-width">
    {%- for block in section.blocks -%}
      <div class="stealth-stats__item" {{ block.shopify_attributes }}>
        <span class="stealth-stats__number" data-target="{{ block.settings.number }}">0</span>
        <span class="stealth-stats__suffix">{{ block.settings.suffix }}</span>
        <span class="stealth-stats__label">{{ block.settings.label }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .stealth-stats {
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stealth-stats__inner {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stealth-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    position: relative;
  }

  .stealth-stats__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -1rem;
    top: 20%;
    height: 60%;
    width: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  .stealth-stats__number {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-button);
    line-height: 1;
    display: inline;
  }

  .stealth-stats__suffix {
    font-family: var(--font-heading-family);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: var(--color-button);
    line-height: 1;
    display: inline;
  }

  .stealth-stats__label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
    margin-top: 0.25rem;
  }

  @media screen and (max-width: 749px) {
    .stealth-stats__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .stealth-stats__item:not(:last-child)::after {
      display: none;
    }
  }
</style>

<script>
  (function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counters = entry.target.querySelectorAll('.stealth-stats__number');
          counters.forEach(counter => {
            const target = parseInt(counter.getAttribute('data-target'), 10);
            if (isNaN(target)) return;
            const duration = 2000;
            const step = Math.max(1, Math.floor(target / (duration / 16)));
            let current = 0;
            const timer = setInterval(() => {
              current += step;
              if (current >= target) {
                current = target;
                clearInterval(timer);
              }
              counter.textContent = current.toLocaleString();
            }, 16);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.stealth-stats').forEach(el => observer.observe(el));
  })();
</script>

{% schema %}
{
  "name": "Stealth Stats Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "number",
          "id": "number",
          "label": "Number",
          "default": 500
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g. +, %, Years)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Engineers Trust Stealth"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stealth Stats Bar",
      "blocks": [
        { "type": "stat", "settings": { "number": 500, "suffix": "+", "label": "Engineers Worldwide" } },
        { "type": "stat", "settings": { "number": 100, "suffix": "+", "label": "Tours & Shows" } },
        { "type": "stat", "settings": { "number": 250, "suffix": "+", "label": "Studios Equipped" } },
        { "type": "stat", "settings": { "number": 5, "suffix": "-Year", "label": "Warranty" } }
      ]
    }
  ]
}
{% endschema %}
