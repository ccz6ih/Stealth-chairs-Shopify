<div class="stealth-press color-{{ section.settings.color_scheme }} gradient">
  <div class="stealth-press__inner page-width">
    {%- if section.settings.heading != blank -%}
      <p class="stealth-press__heading">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="stealth-press__logos">
      <div class="stealth-press__track">
        {%- for block in section.blocks -%}
          {%- if block.settings.logo != blank -%}
            <div class="stealth-press__logo" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ block.settings.name }}">
              {%- endif -%}
                <img
                  src="{{ block.settings.logo | image_url: height: 60 }}"
                  alt="{{ block.settings.name | default: 'Press logo' }}"
                  loading="lazy"
                  height="40"
                  class="stealth-press__logo-img"
                >
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- elsif block.settings.name != blank -%}
            <div class="stealth-press__logo stealth-press__logo--text" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer">
              {%- endif -%}
                <span class="stealth-press__logo-text">{{ block.settings.name }}</span>
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<style>
  .stealth-press {
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stealth-press__heading {
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.5;
    margin: 0 0 1.5rem;
  }

  .stealth-press__logos {
    overflow: hidden;
  }

  .stealth-press__track {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
  }

  .stealth-press__logo {
    flex-shrink: 0;
  }

  .stealth-press__logo-img {
    height: 36px;
    width: auto;
    object-fit: contain;
    opacity: 0.45;
    filter: grayscale(100%) brightness(2);
    transition: all 0.3s ease;
  }

  .stealth-press__logo:hover .stealth-press__logo-img {
    opacity: 1;
    filter: grayscale(0%) brightness(1);
  }

  .stealth-press__logo--text {
    display: flex;
    align-items: center;
  }

  .stealth-press__logo-text {
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.45;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .stealth-press__logo--text a {
    color: inherit;
    text-decoration: none;
  }

  .stealth-press__logo--text:hover .stealth-press__logo-text {
    opacity: 1;
    color: var(--color-button);
  }

  @media screen and (max-width: 749px) {
    .stealth-press__track {
      gap: 1.5rem;
    }

    .stealth-press__logo-img {
      height: 28px;
    }

    .stealth-press__logo-text {
      font-size: 0.85rem;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth As Seen In",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Featured In"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Press Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Publication name",
          "default": "Sound on Sound"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to article"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stealth As Seen In",
      "blocks": [
        { "type": "logo", "settings": { "name": "Sweetwater" } },
        { "type": "logo", "settings": { "name": "Sound on Sound" } },
        { "type": "logo", "settings": { "name": "MusicRadar" } },
        { "type": "logo", "settings": { "name": "Music Industry How To" } },
        { "type": "logo", "settings": { "name": "Pro Audio Design" } }
      ]
    }
  ]
}
{% endschema %}
