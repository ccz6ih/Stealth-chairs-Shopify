<div class="stealth-hero-video color-{{ section.settings.color_scheme }} gradient" style="--hero-min-height: {{ section.settings.min_height }}px;">
  <div class="stealth-hero-video__media">
    {%- if section.settings.video_url != blank -%}
      <video
        class="stealth-hero-video__video"
        autoplay
        muted
        loop
        playsinline
        poster="{{ section.settings.cover_image | image_url: width: 1920 }}"
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.cover_image != blank -%}
      <img
        class="stealth-hero-video__image"
        src="{{ section.settings.cover_image | image_url: width: 1920 }}"
        alt="{{ section.settings.cover_image.alt | default: section.settings.heading }}"
        loading="eager"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.cover_image.aspect_ratio | round }}"
      >
    {%- else -%}
      <div class="stealth-hero-video__placeholder"></div>
    {%- endif -%}

    <div class="stealth-hero-video__overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="stealth-hero-video__content page-width">
    {%- if section.settings.subheading != blank -%}
      <span class="stealth-hero-video__subheading">{{ section.settings.subheading }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="stealth-hero-video__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="stealth-hero-video__text">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="stealth-hero-video__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button button--primary stealth-hero-video__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_button_label != blank -%}
        <a href="{{ section.settings.secondary_button_link }}" class="button button--secondary stealth-hero-video__btn stealth-hero-video__btn--secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          {{ section.settings.secondary_button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="stealth-hero-video__wave">
    <svg viewBox="0 0 1200 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,20 Q50,5 100,20 Q150,35 200,20 Q250,5 300,20 Q350,35 400,20 Q450,5 500,20 Q550,35 600,20 Q650,5 700,20 Q750,35 800,20 Q850,5 900,20 Q950,35 1000,20 Q1050,5 1100,20 Q1150,35 1200,20 L1200,40 L0,40 Z" fill="var(--color-background)"/>
    </svg>
  </div>
</div>

<style>
  .stealth-hero-video {
    position: relative;
    min-height: var(--hero-min-height, 600px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .stealth-hero-video__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .stealth-hero-video__video,
  .stealth-hero-video__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stealth-hero-video__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1f1f21 0%, #2a2a2e 50%, #1f1f21 100%);
  }

  .stealth-hero-video__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(31, 31, 33, var(--overlay-opacity, 0.6)) 0%,
      rgba(31, 31, 33, calc(var(--overlay-opacity, 0.6) * 1.2)) 100%
    );
  }

  .stealth-hero-video__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 4rem 1.5rem;
  }

  .stealth-hero-video__subheading {
    display: inline-block;
    font-family: var(--font-heading-family);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-button);
    margin-bottom: 1rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-button);
    border-radius: 2px;
  }

  .stealth-hero-video__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.05;
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
  }

  .stealth-hero-video__heading.h0 { font-size: clamp(2.5rem, 6vw, 4.5rem); }
  .stealth-hero-video__heading.h1 { font-size: clamp(2rem, 5vw, 3.5rem); }

  .stealth-hero-video__text {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    opacity: 0.85;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .stealth-hero-video__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .stealth-hero-video__btn {
    min-width: 180px;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .stealth-hero-video__btn--secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stealth-hero-video__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    height: 40px;
    line-height: 0;
  }

  .stealth-hero-video__wave svg {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .stealth-hero-video {
      min-height: 500px;
    }

    .stealth-hero-video__content {
      padding: 3rem 1.25rem;
    }

    .stealth-hero-video__actions {
      flex-direction: column;
      align-items: center;
    }

    .stealth-hero-video__btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth Hero Video",
  "tag": "section",
  "class": "section section--full-width",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading badge",
      "default": "THE CHAIR BEHIND THE SOUND"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ENGINEERED FOR THE PEOPLE WHO ENGINEER THE SOUND"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h0", "label": "Extra Large" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h0"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "From the studio to the stage — patented ZenWave technology and custom-fit ergonomic design trusted by the world's top engineers."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "FIND YOUR STEALTH"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "WATCH THE STORY"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4 hosted file)"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image / fallback"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400,
      "max": 900,
      "step": 50,
      "default": 650,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "presets": [
    {
      "name": "Stealth Hero Video"
    }
  ]
}
{% endschema %}
