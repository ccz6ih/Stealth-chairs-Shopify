<div class="stealth-page-hero color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.image != blank -%}
    <div class="stealth-page-hero__bg">
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="eager"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
        class="stealth-page-hero__bg-img"
      >
      <div class="stealth-page-hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- endif -%}

  <div class="stealth-page-hero__inner page-width">
    {%- if section.settings.subheading != blank -%}
      <span class="stealth-page-hero__subheading">{{ section.settings.subheading }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="stealth-page-hero__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="stealth-page-hero__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="stealth-page-hero__cta button button--primary">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

<style>
  .stealth-page-hero {
    position: relative;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .stealth-page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .stealth-page-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stealth-page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 100%);
  }

  .stealth-page-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.text_alignment }};
    text-align: {{ section.settings.text_alignment }};
    padding: 4rem 2rem;
    max-width: 800px;
  }

  .stealth-page-hero__inner[style*="center"] {
    margin: 0 auto;
  }

  .stealth-page-hero__subheading {
    display: inline-block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-button);
    font-weight: 700;
    margin-bottom: 1rem;
    border: 1px solid var(--color-button);
    padding: 0.4rem 1rem;
    border-radius: 2px;
  }

  .stealth-page-hero__heading {
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .stealth-page-hero__text {
    font-size: 1.1rem;
    opacity: 0.8;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 600px;
  }

  .stealth-page-hero__cta {
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  @media screen and (max-width: 749px) {
    .stealth-page-hero {
      min-height: {{ section.settings.min_height | minus: 150 }}px;
    }

    .stealth-page-hero__inner {
      padding: 3rem 1.25rem;
    }
  }
</style>

{% schema %}
{
  "name": "Stealth Page Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 200,
      "max": 600,
      "step": 50,
      "default": 400,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h0", "label": "Extra large" },
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "presets": [
    {
      "name": "Stealth Page Hero"
    }
  ]
}
{% endschema %}
