{% comment %}
  IGNITON ADVISORS & MEDICAL TEAM - ENHANCED
  Dynamic team showcase with rich bios, credentials, and achievements
  Full modal system with extended information and social links
  100% Shopify-compliant with no hardcoded fonts
{% endcomment %}

{% schema %}
{
  "name": "Advisors & Medical Team",
  "tag": "section",
  "class": "igniton-advisors-section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Our Medical Advisory Board"
    },
    {
      "type": "richtext",
      "id": "section_description",
      "label": "Section Description",
      "default": "<p>World-class expertise behind every Igniton formula. Meet the physicians, researchers, and scientists who guide our innovation.</p>"
    },
    {
      "type": "select",
      "id": "grid_layout",
      "label": "Grid Layout",
      "options": [
        {
          "value": "2-column",
          "label": "2 Columns"
        },
        {
          "value": "3-column",
          "label": "3 Columns"
        },
        {
          "value": "4-column",
          "label": "4 Columns"
        }
      ],
      "default": "3-column"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        {
          "value": "modern",
          "label": "Modern (Clean & Minimal)"
        },
        {
          "value": "premium",
          "label": "Premium (With Background Letter)"
        },
        {
          "value": "classic",
          "label": "Classic (Centered Layout)"
        }
      ],
      "default": "premium"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#191880"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D3A23C"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF6F2"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_credentials_on_card",
      "label": "Show Credentials on Card",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_specialties_on_card",
      "label": "Show Specialties on Card Preview",
      "default": false,
      "info": "Shows first specialty below name on card"
    },
    {
      "type": "checkbox",
      "id": "enable_hover_effects",
      "label": "Enable Advanced Hover Effects",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "settings": [
        {
          "type": "header",
          "content": "BASIC INFORMATION"
        },
        {
          "type": "text",
          "id": "full_name",
          "label": "Full Name",
          "default": "Dr. Jane Smith"
        },
        {
          "type": "text",
          "id": "credentials",
          "label": "Credentials",
          "default": "M.D., PhD, FAARM",
          "info": "Professional credentials and degrees"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Professional Title",
          "default": "Board-Certified Physician",
          "info": "Current position or primary title"
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Professional Photo"
        },
        {
          "type": "text",
          "id": "name_initial",
          "label": "Name Initial",
          "default": "J",
          "info": "Single letter for premium card background (only used in Premium card style)"
        },
        {
          "type": "header",
          "content": "SHORT BIO (Shown on Card)"
        },
        {
          "type": "textarea",
          "id": "short_bio",
          "label": "Short Biography",
          "default": "Specializing in integrative medicine and longevity science.",
          "info": "Brief description shown below name on card (2-3 lines max)"
        },
        {
          "type": "header",
          "content": "MODAL CONTENT (Detailed Information)"
        },
        {
          "type": "page",
          "id": "bio_page",
          "label": "Biography Page",
          "info": "Select a Shopify page (e.g., /pages/dr-john-smith) - the page content will be dynamically pulled into the modal"
        },
        {
          "type": "url",
          "id": "full_profile_url",
          "label": "Full Profile Page URL (Optional)",
          "info": "Link to complete profile page if you want a 'View Full Profile' button in modal"
        },
        {
          "type": "textarea",
          "id": "specialties",
          "label": "Areas of Expertise (one per line)",
          "default": "Integrative Medicine\nFunctional Medicine\nLongevity Science\nHormone Optimization",
          "info": "List specialties, one per line"
        },
        {
          "type": "textarea",
          "id": "achievements",
          "label": "Key Achievements (one per line)",
          "default": "Board-certified in Internal Medicine\n20+ years clinical experience\nPublished researcher in longevity science\nFaculty at major medical institutions",
          "info": "Notable accomplishments, one per line"
        },
        {
          "type": "richtext",
          "id": "education",
          "label": "Education & Training",
          "default": "<p><strong>Medical Degree:</strong> Harvard Medical School</p><p><strong>Residency:</strong> Johns Hopkins Hospital</p><p><strong>Fellowship:</strong> Anti-Aging & Regenerative Medicine</p>",
          "info": "Educational background and training"
        },
        {
          "type": "richtext",
          "id": "publications_research",
          "label": "Publications & Research",
          "default": "<p>Author of 50+ peer-reviewed publications in longevity and integrative medicine. Research focuses on mitochondrial health and cellular aging.</p>",
          "info": "Research contributions and publications"
        },
        {
          "type": "textarea",
          "id": "board_certifications",
          "label": "Board Certifications (one per line)",
          "default": "American Board of Internal Medicine\nAmerican Academy of Anti-Aging Medicine (A4M)\nFunctional Medicine Certification",
          "info": "Professional certifications, one per line"
        },
        {
          "type": "header",
          "content": "SOCIAL & PROFESSIONAL LINKS"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn Profile"
        },
        {
          "type": "url",
          "id": "website_url",
          "label": "Personal/Professional Website"
        },
        {
          "type": "url",
          "id": "research_url",
          "label": "Research Profile (Google Scholar, ResearchGate, etc.)"
        },
        {
          "type": "header",
          "content": "STYLING"
        },
        {
          "type": "color",
          "id": "card_accent_color",
          "label": "Card Accent Color",
          "default": "#191880",
          "info": "Unique accent color for this team member's card"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advisors & Medical Team",
      "blocks": [
        {
          "type": "team_member",
          "settings": {
            "full_name": "Dr. Gail King",
            "credentials": "M.D., FACOG, FAARM",
            "title": "Board-Certified Physician in Obstetrics & Gynecology",
            "name_initial": "G",
            "short_bio": "Over three decades of clinical excellence in integrative medicine, specializing in hormone optimization and personalized wellness strategies.",
            "bio_page": "",
