<script>
  (function() {
    // Modal functionality
    const modals = document.querySelectorAll('.advisor-modal');
    const openButtons = document.querySelectorAll('[data-modal-open]');
    const closeButtons = document.querySelectorAll('[data-modal-close]');
    
    // Open modal
    openButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.stopPropagation();
        const modalId = button.getAttribute('data-modal-open');
        const modal = document.querySelector(`[data-modal="${modalId}"]`);
        
        if (modal) {
          modal.classList.add('active');
          document.body.classList.add('modal-open');
        }
      });
    });
    
    // Close modal
    closeButtons.forEach(button => {
      button.addEventListener('click', () => {
        const modalId = button.getAttribute('data-modal-close');
        const modal = document.querySelector(`[data-modal="${modalId}"]`);
        
        if (modal) {
          modal.classList.remove('active');
          document.body.classList.remove('modal-open');
        }
      });
    });
    
    // Close on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const activeModal = document.querySelector('.advisor-modal.active');
        if (activeModal) {
          activeModal.classList.remove('active');
          document.body.classList.remove('modal-open');
        }
      }
    });
    
    // Make entire card clickable
    document.querySelectorAll('.advisor-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', function(e) {
        // Don't trigger if clicking the read more button directly
        if (e.target.closest('.advisor-read-more')) return;
        
        const button = this.querySelector('[data-modal-open]');
        if (button) button.click();
      });
    });
  })();
</script>
