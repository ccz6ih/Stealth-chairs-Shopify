{% comment %}
  Stealth Chair Specs & Testimonials Section
  Combines detailed comparison table with customer success stories
  Features interactive specs table and before/after testimonials
{% endcomment %}

<style>
  .stealth-specs-testimonials {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 100px 20px;
    position: relative;
  }

  .specs-testimonials-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ==================== SPECS TABLE SECTION ==================== */
  
  .specs-section {
    margin-bottom: 120px;
  }

  .specs-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .specs-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #fff 0%, {{ section.settings.accent_color }} 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .specs-subtitle {
    font-size: 1.2rem;
    color: #888;
  }

  .comparison-table-wrapper {
    background: linear-gradient(145deg, #1a1a1a 0%, #0d0d0d 100%);
    border: 2px solid #2a2a2a;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
  }

  .comparison-table thead {
    background: {{ section.settings.accent_color }};
    color: #000;
  }

  .comparison-table th {
    padding: 25px 20px;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: left;
  }

  .comparison-table th:first-child {
    width: 40%;
  }

  .comparison-table tbody tr {
    border-bottom: 1px solid #2a2a2a;
    transition: all 0.3s ease;
  }

  .comparison-table tbody tr:hover {
    background: #1a1a1a;
    transform: scale(1.01);
  }

  .comparison-table tbody tr:last-child {
    border-bottom: none;
  }

  .comparison-table td {
    padding: 25px 20px;
    font-size: 1rem;
    vertical-align: top;
  }

  .spec-category {
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .spec-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .spec-value {
    color: #fff;
    font-weight: 600;
    line-height: 1.6;
  }

  .spec-detail {
    color: #888;
    font-size: 0.9rem;
    margin-top: 5px;
    line-height: 1.5;
  }

  .spec-highlight {
    display: inline-block;
    padding: 4px 12px;
    background: {{ section.settings.accent_color }};
    color: #000;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-top: 8px;
  }

  .checkmark {
    color: {{ section.settings.accent_color }};
    font-weight: 700;
    font-size: 1.2rem;
  }

  /* ==================== TESTIMONIALS SECTION ==================== */

  .testimonials-section {
    position: relative;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .testimonials-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 16px;
    background: linear-gradient(135deg, {{ section.settings.accent_color }} 0%, #fff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .testimonials-subtitle {
    font-size: 1.2rem;
    color: #888;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 450px), 1fr));
    gap: 40px;
  }

  .testimonial-card {
    background: linear-gradient(145deg, #1a1a1a 0%, #0d0d0d 100%);
    border: 2px solid #2a2a2a;
    border-radius: 24px;
    padding: 40px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, {{ section.settings.accent_color }}, #cc0000);
    transform: scaleX(0);
    transition: transform 0.4s ease;
  }

  .testimonial-card:hover {
    border-color: {{ section.settings.accent_color }};
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(255, 0, 0, 0.2);
  }

  .testimonial-card:hover::before {
    transform: scaleX(1);
  }

  .testimonial-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 25px;
  }

  .testimonial-avatar {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid {{ section.settings.accent_color }};
    flex-shrink: 0;
  }

  .testimonial-avatar-placeholder {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, {{ section.settings.accent_color }} 0%, #cc0000 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    flex-shrink: 0;
  }

  .testimonial-info {
    flex: 1;
  }

  .testimonial-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 5px;
  }

  .testimonial-role {
    font-size: 0.95rem;
    color: {{ section.settings.accent_color }};
    font-weight: 500;
  }

  .testimonial-chair-badge {
    display: inline-block;
    padding: 6px 16px;
    background: #1a1a1a;
    border: 1px solid {{ section.settings.accent_color }};
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 8px;
  }

  .testimonial-rating {
    display: flex;
    gap: 5px;
    margin-bottom: 25px;
  }

  .star {
    color: {{ section.settings.accent_color }};
    font-size: 1.2rem;
  }

  .star.empty {
    color: #333;
  }

  .before-after-container {
    margin-bottom: 25px;
  }

  .before-after-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    font-weight: 700;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .timeline-connector {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, {{ section.settings.accent_color }}, transparent);
  }

  .story-section {
    background: #111;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 15px;
    border-left: 3px solid #333;
    transition: all 0.3s ease;
  }

  .story-section:hover {
    border-left-color: {{ section.settings.accent_color }};
    background: #1a1a1a;
  }

  .story-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .story-text {
    font-size: 0.95rem;
    color: #b0b0b0;
    line-height: 1.6;
    font-style: italic;
  }

  .testimonial-quote {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #fff;
    margin-bottom: 20px;
    position: relative;
    padding-left: 25px;
  }

  .testimonial-quote::before {
    content: '"';
    position: absolute;
    left: 0;
    top: -10px;
    font-size: 4rem;
    color: {{ section.settings.accent_color }};
    opacity: 0.3;
    font-family: Georgia, serif;
  }

  .testimonial-result {
    background: linear-gradient(135deg, rgba(255, 0, 0, 0.1) 0%, rgba(255, 0, 0, 0.05) 100%);
    padding: 20px;
    border-radius: 12px;
    border: 1px solid rgba(255, 0, 0, 0.3);
  }

  .result-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    font-weight: 700;
    margin-bottom: 10px;
  }

  .result-text {
    font-size: 1rem;
    color: #fff;
    line-height: 1.6;
    font-weight: 600;
  }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: rgba(0, 255, 0, 0.1);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 20px;
    font-size: 0.8rem;
    color: #0f0;
    font-weight: 600;
    margin-top: 20px;
  }

  /* Mobile Responsive */

  @media (max-width: 968px) {
    .comparison-table-wrapper {
      overflow-x: auto;
    }

    .comparison-table {
      min-width: 600px;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .stealth-specs-testimonials {
      padding: 60px 15px;
    }

    .specs-section,
    .testimonials-section {
      margin-bottom: 60px;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 15px 12px;
      font-size: 0.9rem;
    }

    .testimonial-card {
      padding: 25px 20px;
    }

    .testimonial-header {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<section class="stealth-specs-testimonials">
  <div class="specs-testimonials-container">

    {% comment %} ==================== SPECS COMPARISON TABLE ==================== {% endcomment %}
    
    {% if section.settings.show_specs_table %}
    <div class="specs-section">
      <div class="specs-header">
        <h2 class="specs-title">{{ section.settings.specs_title }}</h2>
        <p class="specs-subtitle">{{ section.settings.specs_subtitle }}</p>
      </div>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Specification</th>
              <th>Stealth Standard</th>
              <th>Stealth Pro</th>
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'spec_row' %}
              <tr {{ block.shopify_attributes }}>
                <td>
                  <div class="spec-category">
                    {% if block.settings.spec_icon != blank %}
                    <span class="spec-icon">{{ block.settings.spec_icon }}</span>
                    {% endif %}
                    {{ block.settings.spec_name }}
                  </div>
                </td>
                <td>
                  <div class="spec-value">{{ block.settings.standard_value }}</div>
                  {% if block.settings.standard_detail != blank %}
                  <div class="spec-detail">{{ block.settings.standard_detail }}</div>
                  {% endif %}
                  {% if block.settings.standard_highlight != blank %}
                  <span class="spec-highlight">{{ block.settings.standard_highlight }}</span>
                  {% endif %}
                </td>
                <td>
                  <div class="spec-value">{{ block.settings.pro_value }}</div>
                  {% if block.settings.pro_detail != blank %}
                  <div class="spec-detail">{{ block.settings.pro_detail }}</div>
                  {% endif %}
                  {% if block.settings.pro_highlight != blank %}
                  <span class="spec-highlight">{{ block.settings.pro_highlight }}</span>
                  {% endif %}
                </td>
              </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% comment %} ==================== TESTIMONIALS SECTION ==================== {% endcomment %}
    
    {% if section.settings.show_testimonials %}
    <div class="testimonials-section">
      <div class="testimonials-header">
        <h2 class="testimonials-title">{{ section.settings.testimonials_title }}</h2>
        <p class="testimonials-subtitle">{{ section.settings.testimonials_subtitle }}</p>
      </div>

      <div class="testimonials-grid">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            
            <div class="testimonial-header">
              {% if block.settings.customer_image != blank %}
              <img 
                src="{{ block.settings.customer_image | img_url: '150x' }}" 
                alt="{{ block.settings.customer_name }}"
                class="testimonial-avatar"
              >
              {% else %}
              <div class="testimonial-avatar-placeholder">
                {{ block.settings.customer_name | slice: 0 }}
              </div>
              {% endif %}

              <div class="testimonial-info">
                <div class="testimonial-name">{{ block.settings.customer_name }}</div>
                <div class="testimonial-role">{{ block.settings.customer_role }}</div>
                {% if block.settings.chair_chosen != blank %}
                <div class="testimonial-chair-badge">{{ block.settings.chair_chosen }}</div>
                {% endif %}
              </div>
            </div>

            {% if block.settings.show_rating %}
            <div class="testimonial-rating">
              {% assign rating = block.settings.rating | plus: 0 %}
              {% for i in (1..5) %}
                {% if i <= rating %}
                  <span class="star">★</span>
                {% else %}
                  <span class="star empty">★</span>
                {% endif %}
              {% endfor %}
            </div>
            {% endif %}

            {% if block.settings.show_before_after %}
            <div class="before-after-container">
              <div class="before-after-label">
                Their Journey
                <div class="timeline-connector"></div>
              </div>

              {% if block.settings.before_story != blank %}
              <div class="story-section">
                <div class="story-label">Before Stealth Chair</div>
                <div class="story-text">{{ block.settings.before_story }}</div>
              </div>
              {% endif %}

              {% if block.settings.after_story != blank %}
              <div class="story-section">
                <div class="story-label">After Stealth Chair</div>
                <div class="story-text">{{ block.settings.after_story }}</div>
              </div>
              {% endif %}
            </div>
            {% endif %}

            {% if block.settings.testimonial_quote != blank %}
            <div class="testimonial-quote">
              {{ block.settings.testimonial_quote }}
            </div>
            {% endif %}

            {% if block.settings.result_text != blank %}
            <div class="testimonial-result">
              <div class="result-label">The Result</div>
              <div class="result-text">{{ block.settings.result_text }}</div>
            </div>
            {% endif %}

            {% if block.settings.verified %}
            <div class="verified-badge">
              <span>✓</span> Verified Purchase
            </div>
            {% endif %}

          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </div>
</section>

