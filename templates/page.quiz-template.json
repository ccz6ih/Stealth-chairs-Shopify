{"sections":{"custom_liquid_r9b4b4":{"type":"custom-liquid","settings":{"custom_liquid":"<!-- Enhanced Stealth Chair Quiz -->\n<style>\n  .stealth-quiz-container {\n    max-width: 900px;\n    margin: 0 auto;\n    padding: 20px;\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;\n  }\n  \n  .stealth-quiz-card {\n    background: #000000;\n    border-radius: 12px;\n    padding: 40px;\n    color: #ffffff;\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\n  }\n  \n  .stealth-intro {\n    text-align: center;\n    margin-bottom: 40px;\n    padding: 20px;\n    border-bottom: 2px solid #ff0000;\n  }\n  \n  .stealth-intro h2 {\n    font-size: 32px;\n    margin-bottom: 15px;\n    font-weight: 700;\n  }\n  \n  .stealth-intro p {\n    font-size: 18px;\n    color: #cccccc;\n    margin-bottom: 20px;\n  }\n  \n  .stealth-feature-highlight {\n    background: rgba(255, 0, 0, 0.1);\n    border-left: 4px solid #ff0000;\n    padding: 15px 20px;\n    margin: 20px 0;\n    border-radius: 0 6px 6px 0;\n    font-size: 16px;\n  }\n  \n  .stealth-progress-container {\n    margin-bottom: 30px;\n  }\n  \n  .stealth-progress {\n    width: 100%;\n    height: 6px;\n    background: #333;\n    margin: 20px 0;\n    border-radius: 3px;\n    overflow: hidden;\n  }\n  \n  .stealth-progress-bar {\n    height: 100%;\n    background: linear-gradient(90deg, #ff0000, #ff3333);\n    border-radius: 3px;\n    transition: width 0.4s ease;\n  }\n  \n  .stealth-progress-text {\n    text-align: center;\n    color: #999;\n    font-size: 14px;\n    margin-top: 10px;\n  }\n  \n  .stealth-question {\n    margin-bottom: 30px;\n  }\n  \n  .stealth-question h3 {\n    font-size: 24px;\n    margin-bottom: 20px;\n    font-weight: 600;\n  }\n  \n  .stealth-educational {\n    background: rgba(255, 255, 255, 0.05);\n    border-radius: 8px;\n    padding: 15px 20px;\n    margin-bottom: 25px;\n    font-size: 15px;\n    line-height: 1.6;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  \n  .stealth-educational-icon {\n    display: inline-block;\n    margin-right: 8px;\n    font-size: 18px;\n  }\n  \n  .stealth-options {\n    display: grid;\n    gap: 15px;\n  }\n  \n  .stealth-option {\n    background: transparent;\n    border: 2px solid #666;\n    color: #ffffff;\n    padding: 18px 24px;\n    border-radius: 8px;\n    cursor: pointer;\n    text-align: left;\n    width: 100%;\n    transition: all 0.2s ease;\n    font-size: 16px;\n    font-weight: 500;\n    position: relative;\n    overflow: hidden;\n  }\n  \n  .stealth-option:hover {\n    border-color: #ff0000;\n    background: rgba(255, 0, 0, 0.05);\n    transform: translateY(-2px);\n  }\n  \n  .stealth-option:active {\n    transform: translateY(0);\n  }\n  \n  .stealth-result {\n    animation: fadeIn 0.5s ease;\n  }\n  \n  @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(20px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n  \n  .stealth-result-header {\n    background: linear-gradient(135deg, #1a1a1a, #2a2a2a);\n    padding: 30px;\n    border-radius: 8px;\n    margin-bottom: 30px;\n    text-align: center;\n  }\n  \n  .stealth-result h3 {\n    font-size: 28px;\n    margin-bottom: 15px;\n  }\n  \n  .stealth-chair-model {\n    color: #ff0000;\n    font-weight: bold;\n    font-size: 36px;\n    display: block;\n    margin: 10px 0;\n  }\n  \n  .stealth-result-content {\n    display: grid;\n    gap: 20px;\n  }\n  \n  .stealth-info-card {\n    background: rgba(255, 255, 255, 0.05);\n    padding: 25px;\n    border-radius: 8px;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  \n  .stealth-info-card h4 {\n    color: #ff0000;\n    margin-bottom: 15px;\n    font-size: 20px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  \n  .stealth-comparison {\n    margin-top: 20px;\n  }\n  \n  .stealth-comparison table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 15px;\n  }\n  \n  .stealth-comparison th {\n    background: rgba(255, 0, 0, 0.1);\n    padding: 12px;\n    text-align: left;\n    font-weight: 600;\n  }\n  \n  .stealth-comparison td {\n    padding: 12px;\n    border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  \n  .stealth-comparison .check {\n    color: #4CAF50;\n    font-weight: bold;\n  }\n  \n  .stealth-comparison .cross {\n    color: #ff6666;\n  }\n  \n  .stealth-testimonial {\n    background: rgba(255, 0, 0, 0.05);\n    border-left: 4px solid #ff0000;\n    padding: 20px;\n    margin: 20px 0;\n    border-radius: 0 6px 6px 0;\n    font-style: italic;\n  }\n  \n  .stealth-testimonial-author {\n    text-align: right;\n    margin-top: 10px;\n    color: #ff0000;\n    font-style: normal;\n    font-weight: 600;\n  }\n  \n  .stealth-specs-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n    gap: 15px;\n    margin-top: 15px;\n  }\n  \n  .stealth-spec-item {\n    background: rgba(0, 0, 0, 0.3);\n    padding: 15px;\n    border-radius: 6px;\n    text-align: center;\n  }\n  \n  .stealth-spec-label {\n    color: #999;\n    font-size: 14px;\n    margin-bottom: 5px;\n  }\n  \n  .stealth-spec-value {\n    color: #fff;\n    font-size: 18px;\n    font-weight: 600;\n  }\n  \n  .stealth-roi-section {\n    background: linear-gradient(135deg, rgba(255, 0, 0, 0.1), rgba(255, 0, 0, 0.05));\n    padding: 25px;\n    border-radius: 8px;\n    margin: 20px 0;\n  }\n  \n  .stealth-roi-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\n    gap: 20px;\n    margin-top: 20px;\n  }\n  \n  .stealth-roi-item {\n    text-align: center;\n  }\n  \n  .stealth-roi-value {\n    font-size: 28px;\n    font-weight: bold;\n    color: #ff0000;\n    display: block;\n  }\n  \n  .stealth-roi-label {\n    font-size: 14px;\n    color: #ccc;\n    margin-top: 5px;\n  }\n  \n  .stealth-buttons {\n    display: flex;\n    gap: 15px;\n    margin-top: 30px;\n    flex-wrap: wrap;\n  }\n  \n  .stealth-button {\n    background: #ff0000;\n    color: #ffffff;\n    padding: 15px 30px;\n    border-radius: 8px;\n    text-decoration: none;\n    border: none;\n    cursor: pointer;\n    font-size: 16px;\n    font-weight: 600;\n    transition: all 0.2s ease;\n    text-align: center;\n    flex: 1;\n    min-width: 200px;\n  }\n  \n  .stealth-button:hover {\n    background: #cc0000;\n    transform: translateY(-2px);\n  }\n  \n  .stealth-button.secondary {\n    background: transparent;\n    border: 2px solid #ff0000;\n  }\n  \n  .stealth-button.secondary:hover {\n    background: rgba(255, 0, 0, 0.1);\n  }\n  \n  .stealth-guarantee {\n    text-align: center;\n    margin-top: 30px;\n    padding: 20px;\n    border-top: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  \n  .stealth-guarantee-badges {\n    display: flex;\n    justify-content: center;\n    gap: 30px;\n    margin-top: 15px;\n    flex-wrap: wrap;\n  }\n  \n  .stealth-guarantee-badge {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    color: #999;\n  }\n  \n  .stealth-guarantee-badge span {\n    font-size: 24px;\n  }\n  \n  @media (max-width: 768px) {\n    .stealth-quiz-card {\n      padding: 20px;\n    }\n    \n    .stealth-intro h2 {\n      font-size: 24px;\n    }\n    \n    .stealth-question h3 {\n      font-size: 20px;\n    }\n    \n    .stealth-option {\n      font-size: 16px;\n      padding: 16px 20px;\n    }\n    \n    .stealth-chair-model {\n      font-size: 28px;\n    }\n    \n    .stealth-buttons {\n      flex-direction: column;\n    }\n    \n    .stealth-button {\n      width: 100%;\n      min-width: auto;\n    }\n    \n    .stealth-comparison {\n      overflow-x: auto;\n    }\n    \n    .stealth-comparison table {\n      min-width: 400px;\n    }\n  }\n<\/style>\n\n<div class=\"stealth-quiz-container\">\n  <div class=\"stealth-quiz-card\">\n    <div class=\"stealth-intro\">\n      <h2>Find Your Perfect Stealth Chair<\/h2>\n      <p>Answer a few questions to get a personalized recommendation<\/p>\n      <div class=\"stealth-feature-highlight\">\n        <strong>Patented ZenWave™ Technology<\/strong> - The only chair that moves with you\n      <\/div>\n    <\/div>\n    \n    <div id=\"quiz-content\">\n      <div class=\"stealth-progress-container\">\n        <div class=\"stealth-progress\">\n          <div class=\"stealth-progress-bar\" style=\"width: 0%\"><\/div>\n        <\/div>\n        <div class=\"stealth-progress-text\">\n          Question <span id=\"current-q\">1<\/span> of <span id=\"total-q\">9<\/span>\n        <\/div>\n      <\/div>\n      \n      <div class=\"stealth-question\">\n        <h3 id=\"question-text\">Loading question...<\/h3>\n        <div id=\"educational-content\" class=\"stealth-educational\"><\/div>\n      <\/div>\n      \n      <div class=\"stealth-options\" id=\"options-container\">\n        <!-- Options will be populated by JavaScript -->\n      <\/div>\n    <\/div>\n    \n    <div id=\"result-content\" style=\"display: none\">\n      <!-- Results will be populated by JavaScript -->\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nconst questions = [\n  {\n    text: \"What's your primary use for the chair?\",\n    educational: \"💡 Different professions require unique support. Audio engineers lean forward 23% more than typical office workers, requiring specialized lumbar support that moves with them.\",\n    options: [\n      { text: \"Music Production\/Audio Engineering\", value: \"audio\" },\n      { text: \"Live Sound\/FOH Engineering\", value: \"live\" },\n      { text: \"Video\/Post Production\", value: \"video\" },\n      { text: \"Lighting Design\/Control\", value: \"lighting\" },\n      { text: \"Other Studio\/Creative Work\", value: \"other\" }\n    ]\n  },\n  {\n    text: \"How many hours do you typically spend sitting per day?\",\n    educational: \"⚠️ After 4 hours of sitting, spinal disc pressure increases by 40%. The ZenWave™ technology reduces this pressure by allowing natural movement.\",\n    options: [\n      { text: \"2-4 hours\", value: \"short\" },\n      { text: \"4-6 hours\", value: \"medium\" },\n      { text: \"6-8 hours\", value: \"long\" },\n      { text: \"8+ hours (marathon sessions)\", value: \"marathon\" }\n    ]\n  },\n  {\n    text: \"Do you currently experience any discomfort during work?\",\n    educational: \"🏥 85% of audio professionals report work-related pain. Early intervention with proper seating prevents career-threatening injuries.\",\n    options: [\n      { text: \"Lower back pain\", value: \"lower_back\" },\n      { text: \"Neck\/shoulder tension\", value: \"neck\" },\n      { text: \"Hip or tailbone discomfort\", value: \"hips\" },\n      { text: \"General fatigue\", value: \"fatigue\" },\n      { text: \"No issues - looking to prevent them\", value: \"prevention\" }\n    ]\n  },\n  {\n    text: \"What chair are you using now?\",\n    educational: \"📊 Most chairs last 2-3 years in professional use. Stealth chairs are built to last 10+ years with a warranty to match.\",\n    options: [\n      { text: \"Basic office\/task chair\", value: \"basic\" },\n      { text: \"Gaming chair\", value: \"gaming\" },\n      { text: \"Herman Miller (Aeron\/Embody)\", value: \"herman\" },\n      { text: \"Other ergonomic chair\", value: \"ergo\" },\n      { text: \"Whatever was available\", value: \"whatever\" }\n    ]\n  },\n  {\n    text: \"What's your height?\",\n    educational: \"📏 Proper seat height is crucial. Your knees should be at 90° with feet flat on the floor. We customize cylinder height to your measurements.\",\n    options: [\n      { text: \"Under 5'6\\\"\", value: \"under56\" },\n      { text: \"5'6\\\" - 5'10\\\"\", value: \"average\" },\n      { text: \"5'10\\\" - 6'2\\\"\", value: \"tall\" },\n      { text: \"Over 6'2\\\"\", value: \"very_tall\" }\n    ]\n  },\n  {\n    text: \"What's your weight range?\",\n    educational: \"💪 Weight distribution affects seat design. Our mesh dynamically adjusts tension to provide perfect support for any body type.\",\n    options: [\n      { text: \"Under 150 lbs\", value: \"under150\" },\n      { text: \"150-200 lbs\", value: \"average_weight\" },\n      { text: \"200-250 lbs\", value: \"above_average\" },\n      { text: \"Over 250 lbs\", value: \"heavy\" }\n    ]\n  },\n  {\n    text: \"How often do you lean forward to work at your console\/desk?\",\n    educational: \"🎛️ Traditional chairs create pressure when leaning forward. ZenWave™ technology tilts the seat with you, maintaining healthy spinal alignment.\",\n    options: [\n      { text: \"Constantly (mixing\/detailed work)\", value: \"constant\" },\n      { text: \"Frequently (active sessions)\", value: \"frequent\" },\n      { text: \"Occasionally\", value: \"occasional\" },\n      { text: \"Rarely (mostly reclined)\", value: \"rarely\" }\n    ]\n  },\n  {\n    text: \"Do you need armrests for your work?\",\n    educational: \"🎸 Many musicians prefer no armrests for instrument access. Our optional 4D armrests can be removed or adjusted completely out of the way.\",\n    options: [\n      { text: \"Yes, essential for support\", value: \"essential\" },\n      { text: \"Nice to have, but removable\", value: \"optional\" },\n      { text: \"No, they get in the way\", value: \"no\" },\n      { text: \"Depends on the task\", value: \"flexible\" }\n    ]\n  },\n  {\n    text: \"Where will you primarily use this chair?\",\n    educational: \"🏢 Different environments need different features. Home studios benefit from style, while commercial facilities need maximum durability.\",\n    options: [\n      { text: \"Home studio\", value: \"home\" },\n      { text: \"Commercial studio\", value: \"commercial\" },\n      { text: \"Live venue\/touring\", value: \"touring\" },\n      { text: \"Multiple locations\", value: \"multiple\" }\n    ]\n  }\n];\n\nconst testimonials = {\n  audio: {\n    quote: \"After putting up with gaming chairs for years, the Stealth has been incredible. The forward tilt when mixing is a game-changer. My back pain is gone.\",\n    author: \"- James K., Audio Engineer\"\n  },\n  live: {\n    quote: \"I've used this chair at FOH for 200+ shows. The portability and comfort during 14-hour festival days is unmatched. Worth every penny.\",\n    author: \"- Sarah M., FOH Engineer\"\n  },\n  health: {\n    quote: \"As a studio owner, I bought 6 Stealth chairs. My engineers' productivity is up, sick days are down. Best investment I've made.\",\n    author: \"- Mike D., Studio Owner\"\n  }\n};\n\nconst products = {\n  stealthStandard: {\n    url: \"https:\/\/stealthchair.com\/products\/stealth-standard-chair-midnight-black-standard-size-seat\",\n    price: 599\n  },\n  stealthPro: {\n    url: \"https:\/\/stealthchair.com\/products\/stealth-pro-chair-midnight-black-large-size-seat\",\n    price: 799\n  },\n  stealthExecutive: {\n    url: \"https:\/\/stealthchair.com\/products\/stealth-executive-audio-engineer-chair\",\n    price: 649\n  },\n  stealthProExecutive: {\n    url: \"https:\/\/stealthchair.com\/products\/stealth-pro-executive-audio-engineer-chair\",\n    price: 749\n  }\n};\n\nlet currentQuestion = 0;\nlet answers = {};\n\nfunction updateProgress() {\n  const progress = ((currentQuestion + 1) \/ questions.length) * 100;\n  document.querySelector('.stealth-progress-bar').style.width = `${progress}%`;\n  document.getElementById('current-q').textContent = currentQuestion + 1;\n  document.getElementById('total-q').textContent = questions.length;\n}\n\nfunction showQuestion() {\n  const question = questions[currentQuestion];\n  document.getElementById('question-text').textContent = question.text;\n  \n  const educationalContent = document.getElementById('educational-content');\n  educationalContent.innerHTML = `<span class=\"stealth-educational-icon\">${question.educational.substring(0, 2)}<\/span>${question.educational.substring(2)}`;\n  \n  const optionsContainer = document.getElementById('options-container');\n  optionsContainer.innerHTML = '';\n  \n  question.options.forEach((option, index) => {\n    const button = document.createElement('button');\n    button.className = 'stealth-option';\n    button.textContent = option.text;\n    button.onclick = () => handleAnswer(option.value, option.text);\n    \n    \/\/ Animate options appearing\n    button.style.opacity = '0';\n    button.style.transform = 'translateY(20px)';\n    setTimeout(() => {\n      button.style.transition = 'all 0.3s ease';\n      button.style.opacity = '1';\n      button.style.transform = 'translateY(0)';\n    }, index * 50);\n    \n    optionsContainer.appendChild(button);\n  });\n  \n  updateProgress();\n}\n\nfunction handleAnswer(value, text) {\n  answers[currentQuestion] = { value, text };\n  \n  if (currentQuestion < questions.length - 1) {\n    currentQuestion++;\n    showQuestion();\n  } else {\n    showResult();\n  }\n}\n\nfunction calculateChairFit() {\n  const heightScore = {\n    under56: { standard: 10, pro: 7 },\n    average: { standard: 10, pro: 10 },\n    tall: { standard: 7, pro: 10 },\n    very_tall: { standard: 5, pro: 10 }\n  };\n  \n  const weightScore = {\n    under150: { standard: 10, pro: 8 },\n    average_weight: { standard: 10, pro: 10 },\n    above_average: { standard: 7, pro: 10 },\n    heavy: { standard: 5, pro: 10 }\n  };\n  \n  const height = answers[4].value;\n  const weight = answers[5].value;\n  \n  return {\n    standardFit: (heightScore[height].standard + weightScore[weight].standard) \/ 2,\n    proFit: (heightScore[height].pro + weightScore[weight].pro) \/ 2\n  };\n}\n\nfunction getRecommendation() {\n  const fitScores = calculateChairFit();\n  const needsPro = fitScores.proFit > fitScores.standardFit && fitScores.standardFit < 8;\n  const leansForward = ['constant', 'frequent'].includes(answers[6].value);\n  const longHours = ['long', 'marathon'].includes(answers[1].value);\n  const hasBackPain = answers[2].value === 'lower_back';\n  \n  \/\/ Determine executive vs standard back\n  const wantsExecutive = longHours || (hasBackPain && answers[1].value !== 'short');\n  \n  let model, url, price, dimensions, seatSize;\n  \n  if (needsPro) {\n    model = wantsExecutive ? 'Stealth Pro Executive' : 'Stealth Pro';\n    url = wantsExecutive ? products.stealthProExecutive.url : products.stealthPro.url;\n    price = wantsExecutive ? products.stealthProExecutive.price : products.stealthPro.price;\n    seatSize = \"Large\";\n    dimensions = {\n      width: \"20.25\\\"\",\n      depth: \"19.5\\\"\",\n      seatHeight: \"22\\\"-28\\\" (short) or 25\\\"-32\\\" (tall cylinder)\"\n    };\n  } else {\n    model = wantsExecutive ? 'Stealth Executive' : 'Stealth Standard';\n    url = wantsExecutive ? products.stealthExecutive.url : products.stealthStandard.url;\n    price = wantsExecutive ? products.stealthExecutive.price : products.stealthStandard.price;\n    seatSize = \"Standard\";\n    dimensions = {\n      width: \"18.5\\\"\",\n      depth: \"16.75\\\"\",\n      seatHeight: \"19.5\\\" (standard) or 25\\\" (extended cylinder)\"\n    };\n  }\n  \n  \/\/ Get cylinder recommendation\n  const cylinderRec = {\n    under56: \"short\/standard\",\n    average: \"standard\",\n    tall: \"tall\/extended\",\n    very_tall: \"tall\/extended\"\n  }[answers[4].value];\n  \n  return {\n    model,\n    url,\n    price,\n    seatSize,\n    dimensions,\n    cylinderRec,\n    leansForward,\n    wantsExecutive,\n    fitScore: needsPro ? fitScores.proFit : fitScores.standardFit,\n    userProfile: {\n      use: answers[0].text,\n      hours: answers[1].text,\n      pain: answers[2].text,\n      currentChair: answers[3].text,\n      height: answers[4].text,\n      weight: answers[5].text\n    }\n  };\n}\n\nfunction generateComparisonTable(currentChair) {\n  const comparisons = {\n    basic: [\n      [\"Forward Tilt Support\", \"✓ Patented ZenWave™\", \"✗ Fixed position\"],\n      [\"Lumbar Support\", \"✓ Dynamic, follows movement\", \"✗ Static or none\"],\n      [\"Build Quality\", \"✓ 10-year warranty\", \"✗ 1-2 year typical\"],\n      [\"Professional Design\", \"✓ Studio