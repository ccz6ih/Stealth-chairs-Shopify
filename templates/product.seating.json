bile":0,"video_subtitle_color":"","video_subtitle_custom_font":false,"video_subtitle_font":"mono","video_subtitle_font_name":"","video_subtitle_font_weight":"default","video_subtitle_margin_top":10,"video_subtitle_font_size":0,"video_subtitle_line_height":0,"video_subtitle_letter_spacing":0,"video_subtitle_margin_top_mobile":10,"video_subtitle_font_size_mobile":0,"video_subtitle_line_height_mobile":0,"video_subtitle_letter_spacing_mobile":0,"video_playing":"popup","video_autoplay":true,"video_loop":false,"video_controls":true,"popup_preview":false,"popup_background_color":"#000000","popup_background_opacity":65,"popup_close_color":"#ffffff","popup_show_arrows":true,"popup_holder_max_width":75,"popup_holder_max_width_portrait":50,"popup_holder_max_width_mobile":75,"popup_holder_max_width_portrait_mobile":75,"popup_holder_background_color":"#000000","popup_holder_border_color":"#ffffff","popup_holder_border_width":4,"popup_holder_border_radius":4,"popup_video_text_display":true,"popup_holder_padding":20,"popup_holder_padding_mobile":20,"popup_video_text_alignment":"center","popup_video_text_alignment_mobile":"center","popup_video_title_type":"h3","popup_video_title_color":"","popup_video_title_custom_font":false,"popup_video_title_font":"mono","popup_video_title_font_name":"","popup_video_title_font_weight":"default","popup_video_title_margin_top":0,"popup_video_title_font_size":0,"popup_video_title_line_height":0,"popup_video_title_letter_spacing":0,"popup_video_title_margin_top_mobile":0,"popup_video_title_font_size_mobile":0,"popup_video_title_line_height_mobile":0,"popup_video_title_letter_spacing_mobile":0,"popup_video_subtitle_type":"h6","popup_video_subtitle_color":"","popup_video_subtitle_custom_font":false,"popup_video_subtitle_font":"mono","popup_video_subtitle_font_name":"","popup_video_subtitle_font_weight":"default","popup_video_subtitle_margin_top":10,"popup_video_subtitle_font_size":0,"popup_video_subtitle_line_height":0,"popup_video_subtitle_letter_spacing":0,"popup_video_subtitle_margin_top_mobile":10,"popup_video_subtitle_font_size_mobile":0,"popup_video_subtitle_line_height_mobile":0,"popup_video_subtitle_letter_spacing_mobile":0}},"collapsible-content":{"type":"collapsible-content","blocks":{"row-2":{"type":"collapsible_row","settings":{"heading":"ABOUT STEALTH","icon":"lightning_bolt","row_content":"","page":"about-stealth-chairs"}},"row-1":{"type":"collapsible_row","settings":{"heading":"DETAILS","icon":"lightning_bolt","row_content":"","page":"stealth-specifications"}},"row-3":{"type":"collapsible_row","settings":{"heading":"SHIPPING","icon":"truck","row_content":"<p><\/p><p><strong>Shipping Varies based on size and location.<\/strong><\/p><p>Each order is custom upholstered, assembled, and inspected before it leaves our facility in Centennial Colorado.<\/p><p>Most orders are completed within 2 weeks' time and shipped within the USA for a total of 3-4 weeks turnaround.<\/p><p>There are times when an order may be placed on backorder and you will be notified by the email and or phone number you provide. <\/p><p>For shipping, we commonly use UPS and have a standard rate of $99 to cover all costs of shipping in the USA. This allows us to ship daily from our facility to you in a timely manner and update your order accordingly. <\/p><p>On some larger orders, it may require custom freight or pallet-based shipping. We will work with our vendors to find the best available rate on shipping and or split an order to get it to you in a timely fashion and or reduce cost. <\/p><p>Once you place an order with Stealth Chairs and you are working with a dealer they will be notified that the order is confirmed and or shipping to make things easier for order transparency. If the order is shipping to the dealer you will still be notified of the order placement and or shipping by email on the order placed. If you would like additional notifications we can send them as well to the emails you provide and or you update VIA your crown seating account. <\/p><p> <\/p><p><strong>If You are outside the USA<\/strong><\/p><p>Please Check with <a href=\"https:\/\/www.universal-distribution.co.uk\/stealth\" title=\"https:\/\/www.universal-distribution.co.uk\/stealth\">https:\/\/www.universal-distribution.co.uk\/stealth<\/a> Shipping will be calculated at check out and we are not responsible for any tariffs involved. You will be notified by the shipping company of these tariffs you are responsible for. We do our best to make sure you get the best rate by DHL, UPS, and or other companies to complete the shipping without additional costs. An average order with custom upholstery outside the USA is about 6-8 Weeks before you receive it. <\/p><p> <\/p><p><strong>Back-ordered based on materials<\/strong><\/p><p>We use the best upholstery, materials, and components to create a seating experience that will last a lifetime. In doing this sometimes certain parts may be back-ordered due to volume, waiting on shipments, and or customized options provided for you. You will always be notified provided by the email on file and or a phone call from a representative to let you know of the new lead time and or options to change the order to expedite delivery. <\/p><p><strong>Working with a dealer<\/strong><\/p><p>When working with a dealer there may be times when your order is not updated by us. This is due to the dealer arranging the best delivery window and or notification has been paused to await other items from additional vendors, parts, and or items that you have placed on a larger order. You will be notified by your dealer on when or where these orders are from Stealth Chairs and if there is a delay the dealer can notify us or you of the expected time window based on the order. <\/p><p><strong>How does the Stealth Chair come and or is it assembled?<\/strong><\/p><p>Each stool may be dissembled based on the best method of shipping. The stool will be detached from the base and cylinder to make shipping easy. Each stool takes an average of 5-15 minutes to assemble out of the box. We do offer fully assembled stools based on your order for additional costs and shipping. Please reach out after you place the order to have it fully assembled and you will receive a separate invoice for this service. <\/p><p><strong>Has my order shipped?<\/strong><\/p><p> Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right-hand side of our site to check the status of your order. How do I change quantities or cancel an item in my order? <\/p><p>Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right-hand side of our site to view orders you have placed. Then click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">Manage your orders<\/a>\" link to find and edit your order.<\/p><p>Please note that once an order has begun processing or has shipped, the order is no longer editable.<\/p><p><strong>How do I track my order?<\/strong> Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right hand side of our site to track your order.<\/p><p><strong>My order never arrived. <\/strong>Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right hand side of our site to track your order status. Be sure that all of the items in your order have shipped already. If you order displays your Package Tracking Numbers, check with the shipper to confirm that your packages were delivered. If your packages each show a status of \"delivered\", please contact customer service for assistance.<\/p><p><strong>An item is missing from my shipment.<\/strong> Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right hand side of our site to track your order status. Be sure that all of the items in your order have shipped already. If you order displays your Package Tracking Numbers, check with the shipper to confirm that your packages were delivered. If your packages each show a status of \"delivered\", please contact customer service for assistance.<\/p><p><strong>My product is missing parts.<\/strong> Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right-hand side of our site to track your order status. Be sure that all of the items in your order have shipped already. If your order displays your Package Tracking Numbers, check with the shipper to confirm that your packages were delivered. If your packages each show a status of \"delivered\", please contact customer service for assistance.<\/p><p><strong>When will my backorder arrive? <\/strong>Backordered items are those which our suppliers are unable to predict when they will have more in stock, but as soon as they do, we will be able to ship the item to you.<\/p><p><strong>International Shipping<\/strong>Do you ship to my country?Please create an account by clicking the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right hand side of our site. During signup, we'll ask for your shipping address details including country. If your country is not in the dropdown menu of available countries, unfortunately, we cannot ship to your country at this time.What are my payment choices?During the checkout process, you may choose any of our current payment options and continue to place your order. Please note that we will not ship your order until we receive payment from you.When will my order ship and what are my shipping charges?Shipping is automatically calculated prior to submit your payment information.  Simply add items to your cart and proceed to the Checkout page where you will be offered Shipping Method choices and their prices. We will ship your order shortly after we receive payment from you.What is the return policy?Please see our<a href=\"https:\/\/www.stealthchairs.com\/policies\/terms-of-service\">Terms & Conditions<\/a>for complete details regarding our return policy.Do I have to pay sales tax?You only have to pay sales tax if you are located in the same state as our warehouse.I have a question on my charges.Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right-hand side of our site to review your orders. You may compare your order history on our website, with your financial records. If you have further questions or concerns, please contact customer service for further assistance.I need a copy of my receipt\/invoice.Click the \"<a href=\"https:\/\/www.stealthchairs.com\/account\">My Account<\/a>\" link at the top right-hand side of our site to print invoices.When will my credit appear on my account?Credits usually take 7-10 business days from the time we receive your item(s).When will my credit card be charged?Your credit card will be charged within 24 hours prior to the shipment of your item(s).<\/p>","page":""}}},"block_order":["row-2","row-1","row-3"],"settings":{"caption":"","heading":"","heading_size":"h1","heading_alignment":"left","layout":"none","container_color_scheme":"background-1","color_scheme":"background-1","open_first_collapsible_row":true,"image_ratio":"large","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"related-products":{"type":"related-products","settings":{"heading":"YOU MAY ALSO LIKE","heading_size":"h1","products_to_show":4,"columns_desktop":4,"columns_mobile":"2","color_scheme":"scheme-1","image_ratio":"portrait","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"padding_top":0,"padding_bottom":40}},"165342407688f42c67":{"type":"apps","settings":{"include_margins":true}}},"order":["main","stealth_trust_badges_PdTprod","stealth_financing_PdTprod","rich_text_qYJ4XX","featured_product_izDPPA","rich_text_ARkTRU","marquee_images_P4bjUD","1715276308447a1795","qq_video_gallery_hefYaK","collapsible-content","related-products","1653